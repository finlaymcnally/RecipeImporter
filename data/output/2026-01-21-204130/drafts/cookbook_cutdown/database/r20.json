          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 350\u02daF/180\u02daC."
        },
        {
          "ingredient_id": "6fd0d84c-a1f7-43dc-9f54-5fd149fed66a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a large pot over medium-high heat, melt the butter."
        },
        {
          "ingredient_id": "68dc0dfc-6141-4e80-a04c-a3c28d2bf5df",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the onion, stir until softened. About 1 minute."
        },
        {
          "ingredient_id": "1eaecf8c-1dcd-4f92-8452-eac51641b758",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Whisk in the flour, stirring constantly to prevent the flour from browning. About 1 minute."
        },
        {
          "ingredient_id": "960d8770-0660-40c6-a80b-a4088245eeb3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Whisk in the chicken broth, salt, and pepper. Continue to whisk until no lumps remain."
        },
        {
          "ingredient_id": "5824cf61-df4f-45c2-bf20-e8154be0a8f5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Whisk in the heavy cream. Bring to a light simmer until the sauce has thickened slightly. Test for additional salt/pepper."
        },
        {
          "ingredient_id": "97880f99-8b10-408b-a8ee-f5c4d679255c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the mixed vegetables and shredded chicken, stir until fully incorporated."
        },
        {
          "ingredient_id": "72fb7f81-7f42-4be9-a427-e0b42c865e2c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Transfer to a 9x13-inch baking dish."
        },
        {
          "ingredient_id": "b9393f66-47fe-46ed-a341-c5b3c113daab",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Evenly top with 12 pieces of biscuit dough (you will have extra biscuits, which can be baked off separately)."
        },
        {
          "ingredient_id": "e98570a2-e9c6-4971-baaf-0865e93746eb",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bake in a preheated oven for 20 minutes, until the biscuits are golden and the gravy mixture is bubbling."
        },
        {
          "ingredient_id": "aa12d216-ff76-4fa6-98ce-9d94b6e90464",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
