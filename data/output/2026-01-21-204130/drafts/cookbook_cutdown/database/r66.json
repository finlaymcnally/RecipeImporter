        },
        {
          "ingredient_id": "bffcd1f2-302d-41ca-87ca-30612cbc9c2c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 1/2 cups self-rising flour (see note)"
        },
        {
          "ingredient_id": "8f2d72dc-cbea-46b0-95c6-a9b58fa31b4e",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 quart peanut, vegetable, or canola oil"
        },
        {
          "ingredient_id": "2d2afe34-babc-4e7c-b005-93dcf3fd5368",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4 soft hamburger buns or potato rolls, toasted"
        },
        {
          "ingredient_id": "0a3ee5e2-f4d1-4a75-ab94-43e8b17efd1f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Directions"
        },
        {
          "ingredient_id": "1aebe73c-7efd-4b83-928e-2f91d25bc783",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1."
        },
        {
          "ingredient_id": "f26317af-468a-48fe-8975-66835967cbb7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour 3/4 cup pickle juice out of pickle jar into a cup. Reserve pickles."
        },
        {
          "ingredient_id": "ffd09856-24d8-4b30-8d58-8ee32c852933",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2."
        },
        {
          "ingredient_id": "3f251ca3-0dc9-4b1d-a0b0-ed3d411d7126",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Season chicken generously with salt and pepper. Place in a plastic zipper-lock bag. Pour in pickle juice. Seal bag, pressing out as much air as possible. Refrigerate and let chicken soak in pickle juice for at least 1 hour and up to 12 hours."
        },
        {
          "ingredient_id": "9b7bc4e3-e95b-4bef-8a61-6551fb0ddbcf",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3."
        },
        {
          "ingredient_id": "fdab3d6c-1573-4a80-8af2-3434b12cb880",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "When ready to fry, remove chicken from bag and discard pickle juice. Pat chicken dry with paper towels. Pour buttermilk into a medium bowl. Add flour and 1 tablespoon pepper to a second bowl. Transfer 3 tablespoons of buttermilk to bowl with flour and work it into the flour with your fingertips."
        },
        {
          "ingredient_id": "fa869f6c-b5fa-415f-82c9-3b9a312f90c0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4."
        },
        {
          "ingredient_id": "bf685d43-41ff-429c-b518-9b00cc5f1fb6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Transfer chicken to bowl with buttermilk and turn to coat. Working with one piece at a time, remove chicken from buttermilk, allowing excess to drip off. Add chicken to bowl with flour and turn, lifting the flour on top of it and pressing it down firmly until a thick, shaggy layer of flour has stuck to the chicken. Transfer to a plate and repeat with remaining chicken pieces."
        },
        {
          "ingredient_id": "d5b28497-3c6b-4c57-8953-09233ebf8525",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "5."
        },
        {
          "ingredient_id": "75d2a34c-de71-4f9a-89ca-734c64800262",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat oil in a wok, deep cast iron skillet, or Dutch oven to 425\u00b0F using a frying thermometer or an instant-read thermometer. Carefully lower chicken pieces into the hot oil; temperature will drop. Adjust flame to maintain a temperature of between 300 and 350\u00b0F. Cook without moving until well browned on first side, about 2 minutes. Flip chicken carefully using tongs and a slotted spatula and cook until second side is browned and chicken is fully cooked, 2 to 3 minutes longer. Transfer to a paper towel\u2013lined plate."
        },
        {
          "ingredient_id": "61659086-7794-4491-80be-8244091ee420",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6."
        },
        {
          "ingredient_id": "f1d24dd2-46ce-44d3-a677-572312b79bc4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place bottom buns on a work surface and top with a few pickles each. Top with fried chicken, followed by top buns. Serve immediately."
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
