          "ingredient_id": "925bd03b-cfa0-4e11-badd-6d61eb46adc3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "are browned and cooked through, about 30 to 40 minutes."
        },
        {
          "ingredient_id": "9ccee741-851b-48ea-a748-6cc4e0a36002",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
