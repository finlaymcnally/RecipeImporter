          "ingredient_id": "a192938e-6d05-463e-beeb-31c26d003949",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place the stew in the oven uncovered and bake until the dumplings"
        },
