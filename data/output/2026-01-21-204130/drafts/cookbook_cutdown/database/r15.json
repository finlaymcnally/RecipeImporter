          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cook the bacon in a large, oven-safe, heavy-based pot or"
        },
        {
          "ingredient_id": "71e4d09c-f699-49e9-8824-4040d2eda4c4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
