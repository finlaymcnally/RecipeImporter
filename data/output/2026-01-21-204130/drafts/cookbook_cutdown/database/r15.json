          "ingredient_id": "891bd24f-4e00-4ec2-8ce7-a5900e927eea",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir the bacon back in. Preheat the oven to 350\u00b0F."
        },
