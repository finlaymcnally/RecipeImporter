          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir together the self-rising flour and garlic powder in a medium"
        },
        {
          "ingredient_id": "d0569665-2011-4778-a9b1-8253c1766414",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "bowl. Cut in the shortening until mixture resembles coarse crumbs."
        },
        {
          "ingredient_id": "57575ee4-fca7-4236-9c7a-b26b59a052c9",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir in the cheddar cheese, then add the milk and stir until the dry"
        },
        {
          "ingredient_id": "86d51a84-2405-47b0-847b-a0eadfcff9de",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "ingredients are moistened."
        },
        {
          "ingredient_id": "24b755d2-8213-4ddb-b6c1-fda92d06c111",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Make small balls with the dough and place them on top of the"
        },
        {
          "ingredient_id": "fd61ab03-b6f4-4518-bffd-aefe26607c72",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "stew, leaving them room to expand\u2013 they grow a lot as they cook."
