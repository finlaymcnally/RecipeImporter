          "ingredient_id": "9d8910f7-ac09-425c-876c-214729e4bf2d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Reduce to a simmer and cover. Simmer for 1 1/2 hours."
        },
        {
          "ingredient_id": "4b768ab3-0c48-41f6-9c9f-8e75533e9f61",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the potatoes or parsnips and the turnip. Simmer for another"
        },
        {
          "ingredient_id": "d2888d2d-99d7-464b-b852-cb03629717a7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u00bd hour, or until the vegetables are tender."
        },
        {
          "ingredient_id": "d9ddbe2a-b793-4882-b69c-c963f0273383",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the bay leaf and thyme branches. If the stew is still"
        },
        {
          "ingredient_id": "c59590da-ecc7-4932-a05f-6c221ad3ac96",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "thin, mix a tablespoon of cornstarch with a tablespoon of cold"
        },
        {
          "ingredient_id": "0a72590d-4fbc-419d-9a6d-e0646bd239f3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "water to form a slurry. Mix the slurry into the stew and bring the"
        },
        {
          "ingredient_id": "b8f4c499-c9bf-4666-848f-ac98bb216b1e",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "mixture to a boil. Reduce to a simmer again, stirring occasionally,"
        },
        {
          "ingredient_id": "7f9be839-2df9-434c-a166-8e16b5cd9c06",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "and add in the mushrooms if desired. Cook for 10 minutes, uncovered,"
        },
        {
          "ingredient_id": "f89bbd96-a230-4f21-a662-00cc37552aad",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "until the stew thickens and the mushrooms are cooked through."
        },
