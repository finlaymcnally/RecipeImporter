          "ingredient_id": "6cc07fdb-c3ee-4743-b315-eb478f8f203b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the bacon, crumble, and set aside, but leave the"
        },
        {
          "ingredient_id": "afebb5b2-70e9-438e-9357-054ded912cf9",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "bacon fat in the pot. Season the beef with salt and pepper and"
        },
        {
          "ingredient_id": "1a58b863-7019-476b-ad59-f3cdfe1cfb21",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "fry in the bacon fat until browned on all sides. Remove the"
        },
        {
          "ingredient_id": "ec329985-5d76-44c2-a0d8-81fadbd66a10",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "beef from the pan and set aside."
        },
        {
          "ingredient_id": "5cb8f8d3-806e-4c13-9698-83adab382a07",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In the same pot, fry the onion, celery, and carrots until soft"
        },
        {
          "ingredient_id": "8cea8edb-5d59-43b7-8cd9-64fd51a482c4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "and fragrant, adding a little oil if necessary."
        },
        {
          "ingredient_id": "c59ca7dc-d71c-4c29-8b87-6bb8bff3648c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add garlic and fry for another 30 seconds. Stir in the tomato paste."
        },
        {
          "ingredient_id": "db6ca649-9e4f-43d2-913a-6a0066d9fc7b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour in the Guinness and Worcestershire sauce. Allow to"
        },
        {
          "ingredient_id": "c1976b54-3daa-48d5-b5f4-9c8bd3083b05",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "come to a simmer and stir with a wooden spoon, scraping up"
        },
        {
          "ingredient_id": "f6f13b9b-9750-409a-a098-b32d2ec0ea7f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "the browned bits from the bottom of the pot."
        },
        {
          "ingredient_id": "68303735-6d93-454d-bb2c-f9b257db22d6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the beef back to the pot and pour in the chicken broth."
