        {
          "ingredient_id": "b2175aab-e0dc-4c60-adc5-4809332a5fce",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 375 degrees F. Lightly oil a 9-inch pie plate or coat with nonstick spray."
        },
        {
          "ingredient_id": "d5df61f4-2cb7-418f-a51a-0f7ef2a6dbf3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a medium saucepan, combine heavy cream, garlic, thyme and nutmeg over medium heat until heated through, about 1-2 minutes."
        },
        {
          "ingredient_id": "ab33a8bd-94aa-4b52-9fe9-808a4d331984",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add a layer of potatoes to the prepared baking dish in an overlapping pattern; season with salt and pepper, to taste. Pour 1/3 cup cream mixture over potatoes; sprinkle with 3 tablespoons Parmesan. Repeat with remaining potato slices, cream mixture and Parmesan to create 2 more layers."
        },
        {
          "ingredient_id": "8637cac0-bde4-40e0-95e7-7903d55ea566",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place into oven and bake until cooked through, about 35-40 minutes. Sprinkle with additional Parmesan and broil for 8-10 minutes, or until top becomes golden brown and crusted."
        },
        {
          "ingredient_id": "56faa252-e531-4195-8f12-97cba9fc1454",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Serve immediately."
        }
