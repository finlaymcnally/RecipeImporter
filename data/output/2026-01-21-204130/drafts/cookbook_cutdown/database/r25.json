          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Strain off the liquid (keep it for aquafaba!), and refrigerate or freeze the chickpeas in whatever portions you like (I prefer 3 cups, as that is the equivalent to two cans of chickpeas)."
