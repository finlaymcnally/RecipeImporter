          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "INSTRUCTIONS"
        },
        {
          "ingredient_id": "9f277cb7-f81a-445c-a57a-5a480a5390e2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat the oven to 400\u00b0F."
        },
        {
          "ingredient_id": "c98f0de3-389b-4493-97df-74fbd2276970",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Season the chicken breast pieces generously with salt and pepper and place in a large, sealable plastic bag."
        },
        {
          "ingredient_id": "b23ba91c-65cb-438a-b9f8-c7f091a3bed7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a medium-sized bowl, combine the sweet Thai chili sauce, lime juice, soy sauce, peanut butter, ginger, and garlic. Pour enough to cover the chicken into the sealable plastic bag. Close, shake around, and allow the chicken to marinate for at least 30 minutes."
        },
        {
          "ingredient_id": "1ffada7c-479f-4622-8a0c-ca900148632c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the chicken from the marinade and place the chicken on a large nonstick baking sheet. Brush the chicken with additional marinade, if desired."
        },
        {
          "ingredient_id": "96a4fe87-440c-494f-aa64-abbefa98c820",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a separate large bowl, toss the bell peppers, broccoli, snow peas, carrots, and onion with the oil and about 1/3 cup\u2019s worth of the chicken marinade. Season with salt and pepper. Lay the vegetables around the chicken and top with lime wheels. Discard all of the remaining marinade that has touched raw chicken."
        },
        {
          "ingredient_id": "f0c9828d-c3d0-47cf-922b-932023bc39b1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bake for about 20 minutes, or until chicken is cooked through and the vegetables are tender."
        },
        {
          "ingredient_id": "aed0321d-9c99-4a35-ae79-8d8d6d33a50d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drizzle the chicken and vegetables with additional marinade, if desired, sprinkle the chicken with the crushed peanuts, and broil to further crisp the vegetables and toast the peanuts, about 2 minutes."
        },
        {
          "ingredient_id": "35b74744-500b-40a6-8b1f-6f1bf9974fd0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Top with cilantro and/or thai basil, and serve over basmati rice with additional sauce, if desired."
        }
      ],
