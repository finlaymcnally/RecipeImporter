          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a bowl, mix soy sauce, ginger, garlic, oyster sauce, sesame oil, sugar, red pepper flakes, and pepper."
        },
        {
          "ingredient_id": "0e7b9475-1df5-44a6-bb37-59cd2906b382",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place chicken cubes into a re-sealable plastic bag pour half of the marinade into the bag and save the rest for later. Let the chicken marinate in the refrigerator for at least an hour."
        },
        {
          "ingredient_id": "f8c95185-729d-414e-b22d-179bf2d91f13",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour the marinated chicken into a large pot and cook over medium-high heat. Remove chicken from the pot."
        },
        {
          "ingredient_id": "e95d9dd6-9561-4696-a0bb-b9fc68d226d1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add sesame oil to the bottom of the pot and add the onion, celery, carrots, and cabbage. Saut\u00e9 until the onions are translucent."
        },
        {
          "ingredient_id": "80a0aed0-cc32-49e1-a2fc-7f1b984549d1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place both of the ramen noodle bricks into the bottom of the pot."
        },
        {
          "ingredient_id": "42b8d3c7-fd1b-47b0-bb61-fc8be5505650",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour in chicken broth over the noodles."
        },
        {
          "ingredient_id": "95a03b7c-4441-4f0e-a0d5-58d13663c267",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cover the noodles with the vegetables as much as possible. Cover the pot with a lid and simmer for 5-7 minutes or until the noodles are cooked through."
        },
        {
          "ingredient_id": "20837c1a-25fd-4750-bb21-bab6d067150f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Break up the noodles and add back the chicken, and pour in the rest of the marinade from earlier."
        },
