        },
        {
          "ingredient_id": "1af7ed2d-6569-485a-a565-ed665ac6b6c9",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Directions"
        },
        {
          "ingredient_id": "e856a7ba-6cda-4a97-94d9-0d142e9d6779",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1."
        },
        {
          "ingredient_id": "063a0c8d-83c0-4c7b-9cd2-9cec792c68bd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Season tuna generously with salt and pepper on all sides."
        },
        {
          "ingredient_id": "e4803c34-2596-48d3-8dc3-cdfe1b0f9a79",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2."
        },
        {
          "ingredient_id": "2b102027-fdac-4e5e-b493-eb455982bd6b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place tuna in a single layer in a gallon-size zipper-lock bag, or in 2 individual quart-size bags. Add olive oil to bag, or divide it between smaller bags, and turn tuna to coat. Add aromatics to bags, if using. Close bags, place in refrigerator, and let tuna rest for at least 30 minutes or up to overnight."
        },
        {
          "ingredient_id": "78a5f1bf-5a3a-4c5c-b71d-d716bbf9c5f3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3."
        },
        {
          "ingredient_id": "e773e0dc-15ba-42d6-88e4-965371426132",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Using your precision cooker, preheat a water bath according to the chart above. Remove the air from the zipper-lock bags using the water displacement method: Seal bag almost all the way, leaving about an inch open. Slowly lower bag into water bath, holding the opened end above the water level. As bag is lowered, the water pressure should force air out of it. Just before it is fully submerged, seal bag completely. Use a rack, or clip bag to the side of cooking vessel using a binder clip, to prevent it from moving excessively."
        },
        {
          "ingredient_id": "0ab8d80e-2d9c-4a77-81e8-9068a3dccf29",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4."
        },
        {
          "ingredient_id": "f6cd87c2-5a6b-4a75-8408-8361c3a21470",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cook 30 to 45 minutes for steaks 1 inch thick or less, or 45 minutes to an hour for steaks between 1 and 2 inches. Carefully remove tuna from bags and transfer to a double layer of paper towels. Discard aromatics and gently blot top of tuna with more paper towels."
        },
        {
          "ingredient_id": "d2d1bf88-b70d-46b6-9869-74071ed6d6f8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "5."
        },
        {
          "ingredient_id": "64919a6f-33c3-4a9b-b82f-372af5ecd459",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For Sashimi- or Canned-Tuna-Style Fish: Wrap tuna in plastic wrap and chill in refrigerator for at least 2 hours and up to overnight. Serve rare tuna like sashimi, or well-done tuna in place of canned tuna in any recipe."
        },
        {
          "ingredient_id": "ffa6b3aa-d8fc-4734-ba82-d1677584bd46",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6."
        },
        {
          "ingredient_id": "d98e43d3-9aaa-4c70-8763-a268e742cbe7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "To Sear: Season tuna aggressively with freshly ground black pepper, or place sesame seeds in a shallow plate and roll tuna steaks to coat on all sides."
        },
        {
          "ingredient_id": "2778e413-0546-44d8-ba77-fdcb46c09a31",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "7."
        },
        {
          "ingredient_id": "ee0cef92-1e26-404c-92bf-cc940fd8e8a8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat vegetable oil in a cast iron, carbon steel, or nonstick skillet over high heat until lightly smoking. Carefully add tuna and cook, without moving, until golden, 30 to 45 seconds. Carefully flip and cook for an additional 30 to 45 seconds. Using tongs, hold tuna upright to sear edges all around. Transfer to paper towels to blot off excess oil, then serve immediately, serving one large steak for every 2 guests."
        }
      ],
