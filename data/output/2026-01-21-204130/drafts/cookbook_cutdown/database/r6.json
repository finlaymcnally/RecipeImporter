          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For best results, always warm your curry sauce before adding it to the curry."
        },
        {
          "ingredient_id": "564e318f-ebf8-409f-8840-add232cb7207",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat the ghee/oil over medium heat in a large pan or wok."
        },
        {
          "ingredient_id": "69007861-27e9-4742-9ce7-9f4aff2d3078",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the dried chillies and cardamoms and allow to sizzle for about 30 seconds."
        },
        {
          "ingredient_id": "57d0e570-0825-4b15-b2a3-314e08989798",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Scoop in the garlic and ginger pastes, the tomato paste and the chopped chilli peppers."
        },
        {
          "ingredient_id": "d66f9737-2494-4112-9cea-a0fb5e58bd27",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Allow them to sizzle for about 15 seconds and then add the cumin, coriander powder, chilli powder, curry powder and turmeric."
        },
        {
          "ingredient_id": "0e0b21ac-3def-4d2c-a808-e4cdc00949f5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir to combine."
        },
        {
          "ingredient_id": "30613773-858f-43e3-8cf2-6dd315091ae0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Now pour in the heated base curry sauce and mango chutney. The ingredients should spit their approval in the hot pan."
        },
        {
          "ingredient_id": "a4c39ea6-b7b0-4c9e-a5ad-ebb233bb10bb",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the pre-cooked chicken pieces and allow to simmer for about three minutes. If you slow cooked your chicken, you could add a tablespoon or two of the broth for extra flavour."
        },
        {
          "ingredient_id": "b9066503-266c-4451-8c10-9772f8e313bc",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Test for seasoning and add a little salt and pepper."
        },
        {
          "ingredient_id": "d7dcbd56-0599-419b-a805-a65b20076ef1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Sprinkle with the fresh coriander and serve."
        },
        {
          "ingredient_id": "c1d76bc8-c3e1-4eec-9632-a39dd6bd8cad",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "A teaspoon of garam masala sprinkled over the top at the end of cooking is a nice touch!"
