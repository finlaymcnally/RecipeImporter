        {
          "ingredient_id": "c729ed3d-d674-4b29-9402-89b9a3b2b4ac",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "PREPARATION"
        },
        {
          "ingredient_id": "94769682-4419-4a53-a0d9-e0f6adaa3604",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a small bowl, combine all spices for the cajun seasoning and mix together. Set aside. Store any extra in an airtight container for future use."
        },
        {
          "ingredient_id": "c065aaaa-246c-450c-ab68-2a4db61937ae",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a heavy bottom pot (such as a Dutch oven), heat 2 tablespoons of olive oil over medium heat."
        },
        {
          "ingredient_id": "ae092f91-438d-4295-82a8-449180369b0a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the sliced chicken and 2\u00bd tablespoons of the prepared cajun seasoning."
        },
        {
          "ingredient_id": "1032ef1b-dd24-4b95-ac37-2662ad8e23bd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the andouille sausage and cook until the chicken is no longer pink, about 4-5 minutes."
        },
        {
          "ingredient_id": "67ddf7e5-607f-4d3f-825b-d0b6cc9b2cf7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the meat from the pot and add the remaining olive oil."
        },
        {
          "ingredient_id": "015145f8-6394-4cf8-a5a5-edb1100efda8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the diced peppers and onions and cook until the onions are transparent and softened, about 5 minutes."
        },
        {
          "ingredient_id": "9c899308-a400-45d6-b13a-10eab1224a19",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the milk and stir so that the seasoning is incorporated into the liquid."
        },
        {
          "ingredient_id": "3a8497e4-6abe-4856-b2ee-7a86a144e1ed",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Turn the heat to high and bring to a boil."
        },
        {
          "ingredient_id": "ceeccb1d-cd83-4587-998a-072a6a051eff",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the uncooked fettuccine, stirring constantly until the noodles are al dente, about 10 minutes."
        },
        {
          "ingredient_id": "25bdcf9b-911a-45e1-aba2-1f3ec3b119d3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "On low heat, add the meat back in and stir so that it\u2019s evenly incorporated."
        },
        {
          "ingredient_id": "0fd2f4f2-0af0-4ff9-ac97-68e5b438f5f8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the cheese and parsley, and stir. Remove from the heat."
        }
      ],
