        },
        {
          "ingredient_id": "a6499ce0-7f2f-4aad-8a0b-1ca6856d488c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "One whole chicken, about 4 pounds, cut into 10 pieces or 3 1/2 pounds bone-in, skin-on breasts, legs, drumsticks, and/or wings"
        },
        {
          "ingredient_id": "e1654b96-ffd4-450a-8d48-d294d20c5899",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 1\u20442 cups all-purpose flour"
        },
        {
          "ingredient_id": "6d03d1a7-baa6-4328-9d11-ed2c56f0069b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1\u20442 cup cornstarch"
        },
        {
          "ingredient_id": "b7cd3c6a-e655-4f91-a18d-de34dc7fce3b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 teaspoon baking powder"
        },
        {
          "ingredient_id": "564f2ea4-2b11-410a-ba3d-806cd57b30a0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4 cups vegetable shortening or peanut oil"
        },
        {
          "ingredient_id": "59633af4-107b-47ad-9aec-75b3955fa41b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Directions"
        },
        {
          "ingredient_id": "65cd71d9-ab5e-47e6-bd48-e57c70687bc7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1."
        },
        {
          "ingredient_id": "518e1d2e-a903-4c0d-9ad7-42cff1cca02b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Combine the paprika, black pepper, garlic powder, oregano, and cayenne in a small bowl and mix thoroughly with a fork."
        },
        {
          "ingredient_id": "0f996c89-96e6-4b8f-9a4b-cd8eb3636a3f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2."
        },
        {
          "ingredient_id": "b95a8d19-9721-4417-afb5-d1a638b49612",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Whisk the buttermilk, egg, 1 tablespoon salt, and 2 tablespoons of the spice mixture in a large bowl. Add the chicken pieces and toss and turn to coat. Transfer the contents of the bowl to a gallon-sized zipper-lock freezer bag and refrigerate for at least 4 hours, and up to overnight, flipping the bag occasionally to redistribute the contents and coat the chicken evenly."
        },
        {
          "ingredient_id": "c5b469cf-455d-4a06-9bdf-3b38d50aa331",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3."
        },
        {
          "ingredient_id": "16408af9-1093-4688-a739-3fb9ab5a7ac2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Whisk together the flour, cornstarch, baking powder, 2 teaspoons salt, and the remaining spice mixture in a large bowl. Add 3 tablespoons of the marinade from the zipper-lock bag and work it into the flour with your fingertips. Remove one piece of chicken from the bag, allowing excess buttermilk to drip off, drop the chicken into the flour mixture, and toss to coat. Continue adding chicken pieces to the flour mixture one at a time until they are all in the bowl. Toss the chicken until every piece is thoroughly coated, pressing with your hands to get the flour to adhere in a thick layer."
        },
        {
          "ingredient_id": "79acb247-7dc5-49e7-9b40-92c0f1a05db4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4."
        },
        {
          "ingredient_id": "c8a3b699-fc78-4106-8602-9bc28d5db50d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Adjust an oven rack to the middle position and preheat the oven to 350\u00b0F. Heat the shortening or oil to 425\u00b0F in a 12-inch straight-sided cast-iron chicken fryer or a large wok over medium-high heat. Adjust the heat as necessary to maintain the temperature, being careful not to let the fat get any hotter."
        },
        {
          "ingredient_id": "6e40266e-4736-4a79-9c78-1152803f2bf6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "5."
        },
        {
          "ingredient_id": "45c6e93f-1052-4eb2-949c-e201417ba24e",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "One piece at a time, transfer the coated chicken to a fine-mesh strainer and shake to remove excess flour. Transfer to a wire rack set on a rimmed baking sheet. Once all the chicken pieces are coated, place skin side down in the pan. The temperature should drop to 300\u00b0F; adjust the heat to maintain the temperature at 300\u00b0F for the duration of the cooking. Fry the chicken until it\u2019s a deep golden brown on the first side, about 6 minutes; do not move the chicken or start checking for doneness until it has fried for at least 3 minutes, or you may knock off the coating. Care- fully flip the chicken pieces with tongs and cook until the second side is golden brown, about 4 minutes longer."
        },
        {
          "ingredient_id": "d78896f1-2614-4ab3-b534-caf1e71fee72",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6."
        },
        {
          "ingredient_id": "303cf36a-c58b-403c-b99b-757033ae4d6f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Transfer the chicken to a clean wire rack set on a rimmed baking sheet and place in the oven. Cook until an instant-read thermometer inserted into the thickest part of the breast registers 150\u00b0F and the legs register 165\u00b0F, 5 to 10 minutes; remove the chicken pieces to a second rack or a paper-towel-lined plate as they reach their final temperature. Season with salt and serve\u2014or, for extra-crunchy fried chicken, go to step 7."
        },
        {
          "ingredient_id": "93f0825d-a8e2-459c-b608-0b237c3bd687",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "7."
        },
        {
          "ingredient_id": "fc1f02b3-79ff-4e52-af82-8f95d45048b6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place the plate of cooked chicken in the refrigerator for at least 1 hour, and up to overnight. When ready to serve, reheat the oil to 400\u00b0F. Add the chicken pieces and cook, flipping them once halfway through cooking, until completely crisp, about 5 minutes. Transfer to a wire rack set on a rimmed baking sheet to drain, then serve immediately."
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
