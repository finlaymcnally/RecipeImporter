          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Method"
        },
        {
          "ingredient_id": "ba9d5aa5-8ba9-402a-be11-05c09e69bdc8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 1"
        },
        {
          "ingredient_id": "6ba61199-99ed-4cdf-a9f1-0bcd499d8bdd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Put \u00bd the thumb-sized piece of ginger, 2 quartered onions and 4 garlic cloves in a food processor with 300ml water. Blitz to a smooth pur\u00e9e."
        },
        {
          "ingredient_id": "3e3c74f4-d670-4541-a40d-ebaa5ff97682",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 2"
        },
        {
          "ingredient_id": "ac1a3fc8-683a-4ca8-b840-2e7b7e6eb4be",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Scrape down the sides with a spoon and blitz again to make it as smooth as you can. Tip into a deep saut\u00e9 pan, cover with a lid and simmer for 15 mins."
        },
        {
          "ingredient_id": "a8436111-5fd4-40bf-8d74-01b9b56f6cd0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 3"
        },
        {
          "ingredient_id": "31a8d25c-eaf8-4fee-9635-144c9bfef95d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the lid and cook for 5 mins more, stirring occasionally. By now the liquid should be all gone. If not, cook a little longer."
        },
        {
          "ingredient_id": "a05797d5-b32e-48fb-8fce-b08c84fad0e7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 4"
        },
        {
          "ingredient_id": "a623000e-372e-4bc3-976c-d961c882be74",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add 2 tbsp rapeseed oil to the pan with the remaining piece of ginger, cut into matchsticks. Turn up the heat and fry, stirring, for 3-5 mins until it starts to colour."
        },
        {
          "ingredient_id": "705960d0-afb0-4721-8e60-5131d671f3cd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 5"
        },
        {
          "ingredient_id": "5beb32d1-2167-48e9-ba51-0627db7dae84",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir in 1 cinnamon stick, 1 tbsp ground coriander, 1 tsp ground cumin, 1 tsp ground turmeric and \u00bd tsp fennel seeds, then add 750g leg of lamb. Stir-fry until the lamb changes colour."
        },
        {
          "ingredient_id": "02b33abd-7fe7-4956-84a8-63fe5d45d2c1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 6"
        },
        {
          "ingredient_id": "ded09741-fbac-446c-a780-69c5b2c38888",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Tip in 400g can chopped tomatoes with a can of water and 1 deseeded and sliced red or green chilli, season well, cover and leave to simmer for 1 hr."
        },
        {
          "ingredient_id": "98e45fc1-f8f8-419b-ac5b-bc163e1cdc36",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 7"
        },
        {
          "ingredient_id": "b23619c5-52fd-4025-b300-0434dd3771ac",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir in the finely chopped stalks from a small bunch coriander, re-cover and cook for a final 30 mins until the lamb is tender. Add a splash of water if necessary to loosen the consistency as it cooks."
        },
        {
          "ingredient_id": "72fde6e4-2a39-4519-bf68-1e979e751013",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "STEP 8"
        },
        {
          "ingredient_id": "7b940c4f-1ed1-4909-aa2f-ef5f75450c68",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir in the roughly chopped coriander leaves and serve with basmati rice and mango chutney or raita."
