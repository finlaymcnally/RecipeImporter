        {
          "ingredient_id": "d45c3897-eaa6-4753-bd22-c372a41240b2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cuban Rice Directions"
        },
        {
          "ingredient_id": "667ce401-65f2-47d6-8ed9-0ba9e83d80a2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "If using dry beans, soak in cold water overnight. Drain and place in a stockpot with fresh water covering the beans. Bring to a boil then reduce and simmer, covered for 1 hour or until beans are tender but firm. Drain the beans by pouring the cooking water into a bowl. Save the water, you will use it later for the rice."
        },
        {
          "ingredient_id": "de4da556-9585-434c-82a1-bc6fa67e2eaf",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the vegetable oil to the stockpot and saut\u00e9 the garlic, pepper, and onion for 2 to 3 minutes until they soften. Stir in the black beans and rice, and add the water you have saved from cooking the beans. Add an additional 2 cups of water."
        },
        {
          "ingredient_id": "e3f86a28-cfa1-4ec6-8993-f8c986dfd11e",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bring the mixture to a boil, then reduce the heat to a simmer and cook until the rice is tender approximately 20 minutes. Stir frequently and check to see if you need additional water to keep the rice from sticking. You can add more water 1/2 cup at a time while it finishes. Just don\u2019t overdo it or your rice will get mushy."
        },
        {
          "ingredient_id": "fde89f98-eb62-42e6-8d3b-c76ca4e32b0f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Once the rice is fully cooked, add the lime juice and salt and pepper to taste. The dish is best served hot. If you like, you can add some chopped bacon at the end. Or serve as a side dish with hearty roasted meat like pork or chicken."
        }
      ],
