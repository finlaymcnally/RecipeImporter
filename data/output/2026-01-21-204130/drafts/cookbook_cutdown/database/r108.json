        },
        {
          "ingredient_id": "dfd21886-a3ca-4963-af6b-08a11b214c5b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/8 tsp cayenne pepper (optional)"
        },
        {
          "ingredient_id": "a458f02e-c369-4146-8f29-134af9bd8a02",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/4 cup butter , cold and diced into small cubes"
        },
        {
          "ingredient_id": "b7d82a5b-f047-4bd2-b579-953410ffffc5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 oz . finely shredded Parmesan cheese (about 1/2 cup packed)"
        },
        {
          "ingredient_id": "03e63c68-832f-43ba-a5ab-f8032b7ae534",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3/4 cup + 2 Tbsp heavy cream"
        },
        {
          "ingredient_id": "b29df9b0-c014-4228-b2ce-f645f58b4867",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Instructions"
        },
        {
          "ingredient_id": "edb0d724-b5f5-46b1-a802-2ba13b9c54d2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place chicken in a slow cooker, pour chicken broth over chicken. Cover with lid and cook on low heat about 5 hours until chicken is cooked through. Remove chicken from slow cooker, dice and set aside."
        },
        {
          "ingredient_id": "3fbc09e7-2f52-4187-8f98-0c920aa1b263",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Strain broth from slow cooker through a fine mesh strainer into a bowl and reserve broth (if you don't have a fine mesh strainer just try to remove the pieces of fat)."
        },
        {
          "ingredient_id": "e8f3bce9-5adf-496d-b1e1-1be81bf75b9f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "To prepare crumble"
        },
        {
          "ingredient_id": "9d87a26c-2990-4528-8f07-e5d3733b3a09",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 450 degree. In a mixing bowl, whisk together flour, baking powder, salt, pepper, garlic powder and optional cayenne pepper. Using your finger tips, cut butter into mixture until mixture resembles coarse crumbs."
        },
        {
          "ingredient_id": "748b5b28-5ab3-4ba1-b372-6ec2ffeb6e72",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Stir in Parmesan cheese. Pour in heavy cream and mix just until combine. Break and drop mixture into 1 - 2-inch pieces onto a Silpat lined baking dish. Bake in preheated oven for 10 minutes until golden. Remove from oven and set aside."
        },
        {
          "ingredient_id": "99d254bd-44e8-4978-929c-2bec73d52386",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "To prepare filling"
        },
        {
          "ingredient_id": "c926af81-a295-48ee-9c6f-390c8af41d27",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat olive oil over medium high heat. Once hot, add diced carrots, onion and celery. Saute vegetables, stirring occasionally until lightly golden and tender, about 5 - 6 minutes."
        },
        {
          "ingredient_id": "937870de-8985-48e0-b27b-8ff52ca4531c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour vegetables into a bowl and set aside. reduce heat to medium, melt butter in saucepan (I like to brown it a bit for and extra layer of flavor), then add in flour and cook, stirring constantly for about 20 seconds (it will be very thick)."
        },
        {
          "ingredient_id": "8d4179f8-8421-4a92-becd-8cbb9fc40817",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "While stirring, slowly add in milk followed by reserved chicken broth, lemon juice, parsley, thyme and season with salt and pepper to taste. Bring mixture just to a boil, then slightly reduce heat and allow to cook about 1 minute longer until thickened, stirring constantly."
        },
        {
          "ingredient_id": "6f9f9cd9-2c2f-448e-a7d6-2739cfc79a9e",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove sauce from heat and add sauteed vegetables, frozen peas and diced chicken to sauce, then toss to evenly coat."
        },
        {
          "ingredient_id": "55dafafa-4e63-4d26-aff6-92ac6d0d2900",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour mixture into a 9-inch pie dish and sprinkle with baked crumble topping (mine fit perfectly in my pie dish but if yours is coming close to the top edge you may want to sit it on top of a cookie sheet to prevent spills in your oven)."
        },
        {
          "ingredient_id": "68c0d692-3795-49b3-a837-8af2b44c0bd6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bake in 400 degree oven until nicely golden about 12 - 14 minutes. Serve warm."
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
