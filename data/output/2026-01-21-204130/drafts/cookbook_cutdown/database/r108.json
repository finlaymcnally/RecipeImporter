        },
        {
          "ingredient_id": "556c11f0-f565-4860-b8ff-695eebe27208",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For the crumble:"
        },
        {
          "ingredient_id": "a23a194b-59b0-4f3c-8945-21f3cce4887c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 1/2 cups all-purpose flour"
        },
        {
          "ingredient_id": "2b55d896-9e5f-4793-ab73-6831ccec97e1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 1/2 tsp baking powder"
        },
        {
          "ingredient_id": "89fdd925-99db-4806-ae33-0c2756df3800",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/2 tsp salt"
        },
        {
          "ingredient_id": "69d21d4f-9ab8-47c7-9ebb-7d10d63b6841",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/4 tsp freshly ground black pepper"
        },
        {
          "ingredient_id": "bcded574-28e8-4141-9858-b3506789d5d8",
          "input_qty": null,
