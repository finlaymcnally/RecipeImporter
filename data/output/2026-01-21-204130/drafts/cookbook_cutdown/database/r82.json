        {
          "ingredient_id": "496eefd5-c938-4bd2-b9aa-c7370518feaf",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Instructions"
        },
        {
          "ingredient_id": "51ceffb5-e990-4470-a745-ac1af3e5263d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 475 degrees. Spray a 18 by 13-inch rimmed baking sheet with non-stick cooking spray. Place bell pepper, carrots, onions and zucchini on baking sheet."
        },
        {
          "ingredient_id": "c5aa5f01-c2f7-44f6-a374-850b1bb5dfc4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drizzle with 1 Tbsp olive oil and season with salt and toss to evenly coat. Roast in preheated oven about 15 minutes until tender, tossing once halfway through roasting."
        },
        {
          "ingredient_id": "31071ee1-abe5-4c09-adb4-cda9d36c5143",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Then if desired move oven rack closer to broiler and broil for about 1 - 2 minutes to add a light char."
        },
        {
          "ingredient_id": "5daa8614-173c-41c2-89b8-d7b310f23fb7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "While vegetables are roasting, in a small mixing bowl whisk together remaining 3 Tbsp olive oil, lemon juice, garlic, cumin, coriander, cinnamon and season with 1/4 tsp salt, set aside."
        },
        {
          "ingredient_id": "cff69f1e-6e61-4b05-9c2f-083a99d940d5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bring chicken broth, 1/2 tsp salt and turmeric to a boil. Place couscous and raisins in a large mixing bowl, pour hot chicken broth over couscous and stir, cover bowl with plastic wrap and let rest for 5 minutes."
        },
        {
          "ingredient_id": "5f7b5be5-a8dc-418b-bf14-7d90395d6bad",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add roasted vegetables, chick peas, almonds, cilantro, mint and lemon mixture to couscous and toss to evenly coat (while seasoning with a little more salt to taste as desired). Serve warm."
        }
      ],
