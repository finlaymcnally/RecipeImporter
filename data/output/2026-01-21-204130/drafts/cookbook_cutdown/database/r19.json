        {
          "ingredient_id": "0bd6b6f5-c06b-4d9f-8e2d-c78bee4bb61d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 450\u00b0F/230\u00b0C."
        },
        {
          "ingredient_id": "9b705a7f-849e-4ad3-bd0b-0da3c4922cb0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Rinse off your potatoes and give them a light scrub to remove any excess dirt. Dry with towel then cut into fries."
        },
        {
          "ingredient_id": "c3d4849c-3d25-4751-a302-d608e87ef913",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a large mixing bowl, combine potatoes, olive oil, salt, garlic powder, and paprika until each fry is fully coated in all of the spices."
        },
        {
          "ingredient_id": "37eb3e16-a171-49ce-b551-d3091cde8015",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place fries on a baking sheet lined with parchment paper and bake at 450\u00b0F/230\u00b0C for 30-35 minutes or until the fries are crispy and golden brown."
        },
        {
          "ingredient_id": "6f473285-8969-4d7d-85a1-1d36db93b969",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Marinate flank steak with salt, pepper, chili powder, oregano, garlic, cilantro, lime juice, and orange juice for 20 minutes."
        },
        {
          "ingredient_id": "e606a363-bc2f-416a-9bb8-c53ef288efe4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat up a cast-iron skillet with 1 tablespoon of canola oil."
        },
        {
          "ingredient_id": "1226be92-5f02-4660-9822-0fff74ac5f5c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place steak in the hot cast-iron skillet and cook for 3 minutes on both sides for a medium cooked steak. Take steak off the heat and let it rest for 10 minutes before dicing."
        },
        {
          "ingredient_id": "9675676b-402e-4b25-afed-162ddaff1bf4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In an ovenproof skillet, place baked french fries, pepper jack cheese, and diced carne asada, then broil until the cheese is melted."
        },
        {
          "ingredient_id": "b2667f54-c401-45f8-ac48-3b7f9b3e7566",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Top with sour cream, guacamole, diced tomatoes, cilantro, and cotija cheese."
        }
