          "raw_text": "INSTRUCTIONS"
        },
        {
          "ingredient_id": "5bcedf74-e508-43fa-8ecd-780a8975598a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Soak the lentils in cold water overnight. Drain, rinse and set aside."
        },
        {
          "ingredient_id": "06bec852-e78b-4438-9b06-981e02ba503a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Press the saut\u00e9 button on the Instant Pot, add the oil and allow it to heat up for a minute. Add the cumin seeds and once they start to brown, add the onion and bay leaf. Stir-fry for 6-7 minutes or until the onion begins to brown."
        },
        {
          "ingredient_id": "1e5ebc9a-57f1-4995-8ea6-b6d96f973613",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the garlic, ginger, spices and stir, then add the tomatoes. Cook for 5 minutes, or until the tomatoes break down."
        },
        {
          "ingredient_id": "e2946a87-3b54-43bd-9194-418e4b39f286",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the lentils to the pot along with the 3 cups of water and mix well."
        },
        {
          "ingredient_id": "5a6ee0c4-f7ce-4ecb-a99d-ae5074b90024",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Secure the lid, close the pressure valve and cook for 30 minutes at high pressure."
        },
        {
          "ingredient_id": "bc038581-5fd2-4e6c-8445-945dbf5eaeda",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Allow the pressure to release naturally."
        },
