        {
          "ingredient_id": "dd1dde84-6c8a-4bec-af0e-87f4f804d850",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 350F. Lightly mist a 9\u201d x 5\u201d x 3\u201d nonstick loaf pan with olive oil spray."
        },
        {
          "ingredient_id": "02b6a13e-0e85-459a-aabf-e5868ee3fdb0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Combine oats and milk in a medium size mixing bowl. Mix well. Let stand for 3 minutes or until oats are softened. Stir in hot sauce until well mixed. Add chicken, celery, carrots, onion, egg whites, and salt. With fork, mix ingredients well. Add blue cheese and gently mix."
        },
        {
          "ingredient_id": "aa38af09-ca04-48b5-b453-6ed54b5c88f2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Transfer mixture to pan and spread so that top is flat. Sprinkle on a couple shakes of hot sauce and spread evenly. Bake 35 to 40 mins or until chicken is no longer pink. Cut into 8 slices. Makes 4 servings."
        },
        {
          "ingredient_id": "f626d70c-d9b9-429b-833e-65144352c73c",
          "input_qty": null,
          "input_unit_id": null,
