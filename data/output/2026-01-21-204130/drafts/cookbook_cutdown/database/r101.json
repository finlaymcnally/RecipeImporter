          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a large bowl, combine 1 cup flour, sugar, salt, and dry yeast. Add milk and softened butter or margarine. Stir in starter. Mix in up to 3 3/4 cups flour gradually, you may need more depending on your climate."
        },
        {
          "ingredient_id": "54211440-9e80-4652-abf7-fadc279229e1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
