          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Turn dough out onto a floured surface, and knead for 8 to 10 minutes. Place in a greased bowl, turn once to oil surface, and cover. Allow to rise for 1 hour, or until doubled in volume."
        },
        {
          "ingredient_id": "b2d0ad73-28f0-4c43-aef6-c0cf79a75fff",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
