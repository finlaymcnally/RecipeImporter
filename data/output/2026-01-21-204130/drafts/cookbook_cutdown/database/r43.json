          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 tablespoons black peppercorns"
        },
        {
          "ingredient_id": "db864e71-4104-4cee-bdd8-0a58d286244a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 tablespoons ground turmeric"
        },
        {
          "ingredient_id": "5e1aecca-9221-426e-be9e-0b7377161f29",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u00bc cup unsweetened shredded coconut"
        },
        {
          "ingredient_id": "34d1cf82-3c16-4e21-8117-470b80f25a61",
