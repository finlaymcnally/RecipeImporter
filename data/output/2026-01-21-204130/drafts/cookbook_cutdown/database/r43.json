{
  "recipe": {
    "description": "I kind of merge the two recipes together\n\nless than 1/2 cup vinegar\nhoney is bomb\ncook chicken separately so it gets rid of it's grease\nlearn how to cook/reduce gravy\n\ncinnamon and brown sugar/honey are secret ingredients",
    "notes": "Tags: Filipino, Main, Normal, chicken thighs, coconut milk, cauliflower",
    "title": "Chicken Adobo",
    "yield_detail": null,
    "yield_phrase": null,
    "yield_unit_name": null,
    "yield_units": 1
  },
  "schema_v": 1,
  "steps": [
    {
      "ingredient_lines": [
        {
