        },
        {
          "ingredient_id": "47a206c5-50ab-4456-bf93-c11fa8088a0a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 medium shallots, chopped"
        },
        {
          "ingredient_id": "bff11d13-483a-4961-b8a2-14dcb226c272",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6 large garlic cloves, chopped"
        },
        {
          "ingredient_id": "0d9ddaaa-4ac7-41c9-833a-a243c413bff8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 3-inch piece ginger, peeled, finely grated"
        },
        {
          "ingredient_id": "a56cc4cd-e24d-4377-927d-57f990a0987d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 teaspoon crushed red pepper flakes"
        },
        {
          "ingredient_id": "7f286fc0-c441-4df4-85c7-6fc4e2deeccd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 13.5-ounce cans unsweetened coconut milk"
        },
        {
          "ingredient_id": "7d7b58fe-d700-49fe-891c-0879a251d49d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 cup sugarcane vinegar or distilled white vinegar, divided"
        },
        {
          "ingredient_id": "8295a8c8-51ee-47ff-80cc-51d7dbc0396a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4 chicken legs, drumsticks and thighs separated"
        },
        {
          "ingredient_id": "5d0b6933-b5f5-4a1b-9ef5-37498e52e80d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3 tablespoons (or more) honey"
        },
        {
          "ingredient_id": "59ffd278-b2e3-4e67-9d21-23a88ed4e719",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Unsalted, roasted pumpkin seeds (pepitas), thinly sliced Fresno chiles, and sliced scallion (for serving)"
        },
        {
          "ingredient_id": "c32dd5c5-0bb4-49ca-a9c2-c1665e243990",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "RECIPE PREPARATION"
        },
        {
          "ingredient_id": "4c349b6f-a062-4d43-8f69-520eaaf5bc72",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place bay leaves and peppercorns in center of cheesecloth and tie closed with kitchen twine; set sachet aside. Toast turmeric in a dry small skillet over medium-low heat, stirring often, just until fragrant (be careful not to let it brown), about 3 minutes. Transfer to a plate."
        },
        {
          "ingredient_id": "d81b52ac-aa1e-439f-af1a-7904f4359595",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cook coconut in same skillet over medium-high heat, stirring occasionally, until burnt (not browned: burnt), about 3 minutes. Grind in a spice mill or with a mortar and pestle or finely chop. Transfer to another plate."
        },
        {
          "ingredient_id": "4ce59bd8-c6e1-4356-be1a-7a6606d2bfd3",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat oven to 375\u00b0. Toss cauliflower and squash on a large rimmed baking sheet with 1 Tbsp. oil to coat; season with salt and pepper. Roast vegetables, tossing occasionally, until browned and tender, 30\u201340 minutes."
        },
        {
          "ingredient_id": "1606d83c-966d-4a3e-bea3-fffae1e17566",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat remaining 2 Tbsp. oil in a large Dutch oven or other heavy pot over medium-high. Add onion, shallots, garlic, and ginger and cook, stirring often, until golden brown and very fragrant, 8\u201310 minutes. Add red pepper flakes and cook, stirring often, just until fragrant, about 1 minute. Stir in toasted turmeric, coconut milk, and \u00be cup vinegar. Bring to a boil and cook until liquid is reduced by about one-third, 20\u201330 minutes."
        },
        {
          "ingredient_id": "bee15a9c-92a7-4cfc-9615-cfa755689f27",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Meanwhile, prepare a grill for medium-high heat (or heat a grill pan over medium-high). Season chicken with salt and pepper and grill, turning occasionally, just until skin is charred (chicken will not be cooked through at this point), 8\u201310 minutes."
        },
        {
          "ingredient_id": "8738f6d4-96fe-46fd-adbf-2717236a7bf4",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add chicken and reserved sachet to turmeric sauce. Cook, partially covered, until chicken is tender, 60\u201380 minutes. Stir honey and remaining \u00bc cup vinegar in a small bowl until honey is dissolved; add to braise, then add roasted cauliflower and squash. Taste and season with more salt or honey as needed."
        },
        {
          "ingredient_id": "73a59224-6c58-4c52-b122-b1e8ab254731",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Divide adobo among bowls and top with burnt coconut, pumpkin seeds, chiles, and scallion."
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
}