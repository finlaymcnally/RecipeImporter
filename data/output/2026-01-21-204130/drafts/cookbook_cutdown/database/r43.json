          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u00bd head of cauliflower, broken into small florets"
        },
        {
          "ingredient_id": "67100f0b-3c2d-436e-be37-58e1074dfd10",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u00bc kabocha squash, cut into 1-inch pieces (about 2 cups)"
        },
        {
          "ingredient_id": "30ffb64a-4d34-4096-9c77-75f56c8addfb",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3 tablespoons vegetable oil, divided"
        },
        {
          "ingredient_id": "368dfcb5-514e-4fba-8f94-9865d871cb73",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Kosher salt, freshly ground pepper"
        },
        {
          "ingredient_id": "f2eea27e-1fa8-4633-9e77-b0e7f966be52",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
