          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Ingredients"
        },
        {
          "ingredient_id": "b85608d7-9f09-4d28-a0d5-a6516ecd1a9c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/4 cup (65 ml) soy sauce"
        },
        {
          "ingredient_id": "74bff754-b7dc-424a-9bcb-ad6589b8643f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/2 cup (125 ml) white Filipino cane vinegar, or distilled white vinegar"
        },
        {
          "ingredient_id": "74494b72-d362-4944-9bbc-45d2730c9b0b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6\u20138 cloves garlic, smashed with the side of a knife and peeled"
        },
        {
          "ingredient_id": "72665bb5-76b2-4980-bddb-2de42b1adc38",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 teaspoon whole black peppercorns"
        },
        {
          "ingredient_id": "a9826c68-fd6b-476b-ab49-a1f92f6765de",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 bay leaves"
        },
        {
          "ingredient_id": "855b93f0-4032-4020-9169-843a788cc42d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6 skin-on, bone-in chicken thighs"
        },
        {
          "ingredient_id": "b4a0852e-b33a-4dd7-985b-9e74f5c23956",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Can add coconut milk"
        },
        {
          "ingredient_id": "fd6ce39f-0552-4d70-afc2-0bfbfc3b86ed",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Directions"
        },
        {
          "ingredient_id": "f2e75e14-9cf0-40b5-ab63-62bd1d91559d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1."
        },
        {
          "ingredient_id": "96566332-5984-442e-abcc-d6b58e09ab68",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place the soy sauce, vinegar, garlic, black peppercorns, and bay leaves in a large, nonreactive saut\u00e9 pan, and then nestle the chicken thighs, skin side down, into the pan. Bring the liquid to a boil over high heat, and then cover and simmer over low heat for 20 minutes. Turn the chicken over, and then cover and simmer for another 10 minutes."
        },
        {
          "ingredient_id": "23c1b6a7-5fea-4c01-82a4-59357ee1b836",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2."
        },
        {
          "ingredient_id": "15db1c91-79d4-4b4c-8579-da25bcee1b44",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Uncover the pan, and then increase the heat to high and return the sauce to a boil. While occasionally turning and basting the chicken, continue boiling the sauce, uncovered, until it is reduced by half and thickens slightly, 5\u20137 minutes. Serve with steamed white rice."
        },
        {
          "ingredient_id": "ee8ec984-0149-4096-a2d5-1dfd0a9c27ee",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3."
        },
        {
          "ingredient_id": "e37a9ce9-e537-406b-91f7-eb2d6d5f91af",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Variations: While the sauce is reducing, transfer the chicken thighs, skin side up, to a foil-lined sheet pan. Brown the chicken thighs underneath the broiler for 3\u20135 minutes."
        },
        {
          "ingredient_id": "2505ce6c-3dd6-4c4a-a7cf-f875c08350f6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Use freshly ground black pepper instead of whole peppercorns."
        },
        {
          "ingredient_id": "f5c95332-d67a-4241-af69-4b84b21d5d1c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For a \u201cdrier\u201d chicken adobo, you can reduce the sauce until it is almost completely evaporated. The chicken will then begin to fry in its own fat that is still left in the pan. This is how my grandmother finishes her adobo."
        },
        {
          "ingredient_id": "aef31d34-b749-4945-b70d-839366a0f19b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For a saucier adobo, double the amount of soy sauce and vinegar."
        },
        {
          "ingredient_id": "c0cce2b7-bca7-41bd-983e-b7e1d1addb13",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "OTHER ONE"
        },
        {
          "ingredient_id": "31022790-40c3-4c9f-b565-2fcc5043fd17",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "INGREDIENTS"
        },
