          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 teaspoon sugar"
        },
        {
          "ingredient_id": "97c820a6-d3b0-4b04-b143-788a80f86130",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
