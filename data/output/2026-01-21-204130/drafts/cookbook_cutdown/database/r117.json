          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 pound pork loin or boneless pork chops"
        },
        {
          "ingredient_id": "ef99d591-1ef8-4aea-ab73-6f12eb991486",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 tablespoons soy sauce (use gluten-free soy sauce if cooking gluten-free)"
        },
        {
