          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat oven to 400\u02daF/200\u02daC."
        },
        {
          "ingredient_id": "029d9d66-783b-48ba-8856-60505f2a7887",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a large bowl, evenly season chicken thighs with salt, pepper, paprika, and parsley."
        },
        {
          "ingredient_id": "f4118ec7-ee02-47a9-8b42-5c4ab0ccf233",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "On high, heat olive oil in a oven-proof pot and place chicken thighs, skin-side down, in the hot oil. Cook 5-6 minutes or the thighs develop brown crispy skin and flip over. Cook an additional 5-6 minutes to brown the other side and remove from the pot."
        },
        {
          "ingredient_id": "1ea170c5-ca3d-445e-889d-c98cd68c8a7b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the garlic and onions to the pot, and cook until the onions are transparent."
        },
        {
          "ingredient_id": "fd5e3b40-9e69-4030-b0e6-f68e4bc35a96",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pour in the rice and chicken broth to the pot and season with salt and pepper. Stir well, bringing to a boil."
        },
        {
          "ingredient_id": "5edc2f16-3fdd-4705-97d6-532c66eaa780",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the chicken thighs back into the pot, skin-side up, on top of the rice, bring back to a boil and cover with a lid."
        },
        {
          "ingredient_id": "ffad6aed-e8d8-410c-8405-7ebbdcda108b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bake for 35-40 minutes, or until the rice is fully cooked."
        },
