          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "DIRECTIONS"
        },
        {
          "ingredient_id": "0025aeda-0e7a-4ab5-9825-00dcee94315f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Rinse and sort beans and place in a stockpot."
        },
        {
          "ingredient_id": "b966a5a4-1d60-4827-b196-46360e99ee78",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cover with several inches of water and soak overnight,-or- bring to a boil, boil gently for 3 minutes, then remove from heat, cover, and allow to sit undisturbed for 1 hour."
        },
        {
          "ingredient_id": "ff320add-231b-4e47-a093-c941d49d83e1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drain and rinse beans."
        },
        {
          "ingredient_id": "ed1519cd-4657-49e0-88f4-b383177df037",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bring to a boil with chicken stock, water, and coconut cream."
        },
        {
          "ingredient_id": "79d6f6b4-a609-47c2-a464-4d18505ad86f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Cover, reduce heat, and simmer for 1 1/2-2 hours or until beans are tender and creamy."
        },
        {
          "ingredient_id": "518849ea-5be2-4eeb-acb5-9142f23b292f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Add the thyme, allspice, scallion, onion, garlic, scotch bonnet, brown sugar, uncooked rice, salt and pepper."
        },
        {
          "ingredient_id": "2bcc96a9-ebed-4be5-b589-887fe84c66c7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Check the level of liquid over the rice and make sure there is at least one inch of liquid (if not, you may add water or broth to cover)."
        },
        {
          "ingredient_id": "6f73a9a2-52f7-467d-ac6c-4731ee93a663",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Bring to a boil, reduce heat, cover and simmer for 20-30 minutes or until rice is tender."
        },
        {
          "ingredient_id": "2c81c982-4184-4822-9ed5-0d7824cd0eb1",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Serve hot as a side dish, with Jamaican hot sauce as a condiment, if desired."
        },
        {
          "ingredient_id": "4fa790aa-9bbe-4e89-ba6f-3dd1827eea9c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "For Vegetarian use water not the chicken broth or stock."
        }
