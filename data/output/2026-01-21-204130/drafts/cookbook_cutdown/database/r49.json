        },
        {
          "ingredient_id": "c9a2eb21-85ef-48d4-81ef-0a49dc9ea1fc",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1."
        },
        {
          "ingredient_id": "fade2ab7-8c89-449a-8b79-7c5a62615b3c",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Adjust oven rack to 6 to 8 inches below broiler element and preheat broiler to high. Heat oil in a large cast iron skillet over high heat until shimmering. Reduce heat to medium and wipe out excess oil with a paper towel."
        },
        {
          "ingredient_id": "1926dfaa-cf27-4b62-ba17-0b70f32a5756",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2."
        },
        {
          "ingredient_id": "809a464f-c2e5-4bec-94c2-1295ad69c853",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place tortilla in skillet with the rougher textured-side facing down. Spread sauce evenly over tortilla all the way to the edges. Spread mozzarella and half of Parmesan evenly over tortilla all the way to the edges. Season lightly with salt. Sprinkle with onion and bell pepper. Lay pepperoni and sausage chunks over pizza. Scatter with basil."
        },
        {
          "ingredient_id": "c61abf49-6df9-467c-b54e-6fc25adabd05",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3."
        },
        {
          "ingredient_id": "6f474d67-44b0-4eae-a1aa-09e0eaafc140",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place skillet under broiler and broil until sausage is cooked through and cheese is melted and starting to brown in spots, 2 to 4 minutes. Remove from oven and sprinkle with remaining Parmesan. Using a small metal spatula, gently pry edges of pizza, releasing the cheese from the skillet. Peek under bottom. If more crispness is desired, place skillet over medium heat and cook, swirling pizza and peeking occasionally, until desired crispness is achieved. Slide pizza out onto a cutting board. Cut and serve immediately."
        }
