    {
      "ingredient_lines": [],
      "instruction": "Place chicken cubes into a re-sealable plastic bag pour half of the marinade into the bag and save the rest for later. Let the chicken marinate in the refrigerator for at least an hour."
    },
    {
      "ingredient_lines": [],
      "instruction": "Pour the marinated chicken into a large pot and cook over medium-high heat. Remove chicken from the pot."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add sesame oil to the bottom of the pot and add the onion, celery, carrots, and cabbage. Saut\u00e9 until the onions are translucent."
    },
    {
      "ingredient_lines": [],
      "instruction": "Place both of the ramen noodle bricks into the bottom of the pot."
    },
    {
      "ingredient_lines": [],
      "instruction": "Pour in chicken broth over the noodles."
    },
    {
      "ingredient_lines": [],
      "instruction": "Cover the noodles with the vegetables as much as possible. Cover the pot with a lid and simmer for 5-7 minutes or until the noodles are cooked through."
    },
    {
      "ingredient_lines": [],
      "instruction": "Break up the noodles and add back the chicken, and pour in the rest of the marinade from earlier."
    },
    {
      "ingredient_lines": [],
      "instruction": "Garnish with scallions."
    },
    {
