    {
      "ingredient_lines": [],
      "instruction": "Heat the ghee/oil over medium heat in a large pan or wok."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the dried chillies and cardamoms and allow to sizzle for about 30 seconds."
    },
    {
      "ingredient_lines": [],
      "instruction": "Scoop in the garlic and ginger pastes, the tomato paste and the chopped chilli peppers."
    },
    {
      "ingredient_lines": [],
      "instruction": "Allow them to sizzle for about 15 seconds and then add the cumin, coriander powder, chilli powder, curry powder and turmeric."
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir to combine."
    },
    {
      "ingredient_lines": [],
      "instruction": "Now pour in the heated base curry sauce and mango chutney. The ingredients should spit their approval in the hot pan."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the pre-cooked chicken pieces and allow to simmer for about three minutes. If you slow cooked your chicken, you could add a tablespoon or two of the broth for extra flavour."
    },
    {
      "ingredient_lines": [],
      "instruction": "Test for seasoning and add a little salt and pepper."
    },
    {
      "ingredient_lines": [],
      "instruction": "Sprinkle with the fresh coriander and serve."
    },
    {
      "ingredient_lines": [],
      "instruction": "A teaspoon of garam masala sprinkled over the top at the end of cooking is a nice touch!"
