      "instruction": "STEP 1"
    },
    {
      "ingredient_lines": [],
      "instruction": "Put \u00bd the thumb-sized piece of ginger, 2 quartered onions and 4 garlic cloves in a food processor with 300ml water. Blitz to a smooth pur\u00e9e."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 2"
    },
    {
      "ingredient_lines": [],
      "instruction": "Scrape down the sides with a spoon and blitz again to make it as smooth as you can. Tip into a deep saut\u00e9 pan, cover with a lid and simmer for 15 mins."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 3"
    },
    {
      "ingredient_lines": [],
      "instruction": "Remove the lid and cook for 5 mins more, stirring occasionally. By now the liquid should be all gone. If not, cook a little longer."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 4"
    },
    {
      "ingredient_lines": [],
      "instruction": "Add 2 tbsp rapeseed oil to the pan with the remaining piece of ginger, cut into matchsticks. Turn up the heat and fry, stirring, for 3-5 mins until it starts to colour."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 5"
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in 1 cinnamon stick, 1 tbsp ground coriander, 1 tsp ground cumin, 1 tsp ground turmeric and \u00bd tsp fennel seeds, then add 750g leg of lamb. Stir-fry until the lamb changes colour."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 6"
    },
    {
      "ingredient_lines": [],
      "instruction": "Tip in 400g can chopped tomatoes with a can of water and 1 deseeded and sliced red or green chilli, season well, cover and leave to simmer for 1 hr."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 7"
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in the finely chopped stalks from a small bunch coriander, re-cover and cook for a final 30 mins until the lamb is tender. Add a splash of water if necessary to loosen the consistency as it cooks."
    },
    {
      "ingredient_lines": [],
      "instruction": "STEP 8"
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in the roughly chopped coriander leaves and serve with basmati rice and mango chutney or raita."
    }
