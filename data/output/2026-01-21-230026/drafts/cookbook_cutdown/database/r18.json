      "instruction": "Preheat the oven to 400\u00b0F."
    },
    {
      "ingredient_lines": [],
      "instruction": "Season the chicken breast pieces generously with salt and pepper and place in a large, sealable plastic bag."
    },
    {
      "ingredient_lines": [],
      "instruction": "In a medium-sized bowl, combine the sweet Thai chili sauce, lime juice, soy sauce, peanut butter, ginger, and garlic. Pour enough to cover the chicken into the sealable plastic bag. Close, shake around, and allow the chicken to marinate for at least 30 minutes."
    },
    {
      "ingredient_lines": [],
      "instruction": "Remove the chicken from the marinade and place the chicken on a large nonstick baking sheet. Brush the chicken with additional marinade, if desired."
    },
    {
      "ingredient_lines": [],
      "instruction": "In a separate large bowl, toss the bell peppers, broccoli, snow peas, carrots, and onion with the oil and about 1/3 cup\u2019s worth of the chicken marinade. Season with salt and pepper. Lay the vegetables around the chicken and top with lime wheels. Discard all of the remaining marinade that has touched raw chicken."
    },
    {
      "ingredient_lines": [],
      "instruction": "Bake for about 20 minutes, or until chicken is cooked through and the vegetables are tender."
    },
    {
      "ingredient_lines": [],
      "instruction": "Drizzle the chicken and vegetables with additional marinade, if desired, sprinkle the chicken with the crushed peanuts, and broil to further crisp the vegetables and toast the peanuts, about 2 minutes."
    },
    {
      "ingredient_lines": [],
      "instruction": "Top with cilantro and/or thai basil, and serve over basmati rice with additional sauce, if desired."
    }
