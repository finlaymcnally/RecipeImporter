  "recipeIngredient": [
    "2 cucumbers",
    "8 lamb loin chops, about 120-150g each",
    "salt and freshly ground black pepper",
    "vegetable or corn oil for brushing",
    "2 tbsp cold-pressed rapeseed oil",
    "2 large shallots, peeled, halved and thinly sliced"
