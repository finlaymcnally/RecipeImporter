  "identifier": "urn:recipeimport:pdf:020e5142342e0bef5a211cd74199e35cae8dfbb1e66163f7856ffd071629ccb9:c12",
  "name": "CHILLED GOLDEN BEETROOT SOUP",
  "recipeIngredient": [
    "400g medium yellow beetroot",
    "salt and freshly ground black pepper",
    "1 tbsp cold-pressed rapeseed or olive 011",
    "1 small onion, peeled and roughly chopped",
    "1 litre vegetable stock",
    "To finish",
    "1 tbsp freshly grated horseradish"
  ],
  "recipeInstructions": [
    "Cook the beetroot in a pan of salted water for about 1 hour until they feel tender when pierced with a knife. Drain and leave until cool enough to handle, then peel and roughly chop the beetroot.",
    "Heat the oil in a large saucepan, add the onion, cover and cook gently for 3- 4 minutes to soften. Add the vegetable stock, bring to the boil, season with a little salt and pepper and simmer for 30 minutes.",
    "Add the beetroot, then remove from the heat. Puree in a blender until smooth, then pass the soup through a fine-meshed sieve into a large bowl.",
    "Re-season if necessary. Cool the soup down, then refrigerate for a few hours until well chilled or put it into the freezer if you're in a rush.",
    "Serve in soup plates topped with a dollop of cream, creme fraTche or soft goat's cheese and a sprinkling of grated horseradish."
  ],
  "recipeYield": "Serves 4",
