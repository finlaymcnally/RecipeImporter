  "identifier": "urn:recipeimport:pdf:020e5142342e0bef5a211cd74199e35cae8dfbb1e66163f7856ffd071629ccb9:c24",
  "name": "BAKED NEW SEASON'S GARLIC SAUCE",
  "recipeIngredient": [
    "4 heads of new season's garlic",
    "a few sprigs of curly parsley",
    "2-3 tbsp duck fat, warmed (or pan juices from",
    "a roasted chicken)",
    "70g fresh white breadcrumbs",
    "a little milk to mix"
  ],
  "recipeInstructions": [
    "Preheat the oven to 200\u00b0C/gas mark 6. Wrap the garlic bulbs in foil and bake them in the oven for 1 hour. Unwrap and leave until cool enough to handle, then peel away any tough outer skin.",
    "Put the garlic into a blender with the parsley, mustard, warm duck fat (or chicken pan juices) and breadcrumbs and blend until smooth. Add enough and mustard.",
    "milk to give the sauce a thick pouring consistency and season with salt and pepper to taste."
  ],
  "recipeYield": "Serves 4",
