      "instruction": "TO COOK:"
    },
    {
      "ingredient_lines": [],
      "instruction": "The night before cooking, move the frozen bag to your refrigerator to thaw."
    },
    {
      "ingredient_lines": [],
      "instruction": "The morning of cooking, pour contents of freezer bag into your crockpot and cook on \u201clow\u201d setting for 6 hours or until chicken is tender."
