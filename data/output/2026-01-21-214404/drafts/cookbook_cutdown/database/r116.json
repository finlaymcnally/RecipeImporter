{
  "recipe": {
    "description": null,
    "notes": "Tags: Side, Normal, potatoes",
    "title": "Roasted Smashed potatoes",
    "yield_detail": null,
    "yield_phrase": null,
    "yield_unit_name": null,
    "yield_units": 1
  },
  "schema_v": 1,
  "steps": [
    {
      "ingredient_lines": [
        {
          "ingredient_id": "e0541a10-6d02-47ee-b23e-3132aecef712",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "INGREDIENTS"
        },
        {
          "ingredient_id": "f3aad477-4b7c-4634-8779-d9073eb98390",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 lb. baby red bliss or yukon gold potatoes (you want them to be small \u2013 like, golfball size \u2013 about 18 potatoes)"
        },
        {
          "ingredient_id": "569df91a-3dc9-4af1-b523-cd2d34d45756",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6 tbsp olive oil, divided"
        },
        {
          "ingredient_id": "f4ab37fd-dda4-4e98-baeb-15fd7ed29fbb",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 tsp fresh thyme, chopped (feel free to substitute with rosemary, basil, garlic, parmesan)"
        },
        {
          "ingredient_id": "7a2f4851-ea3e-4aa4-80bb-903e93d9affe",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Salt and pepper, to taste"
        },
        {
          "ingredient_id": "f4d1ca28-faa8-431f-95fa-0949485a313b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "HOW TO MAKE IT"
        },
        {
          "ingredient_id": "5828a26c-92a7-45f2-8bd4-f2ada3cb1335",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat the oven to 500\u00b0F"
        },
        {
          "ingredient_id": "355704c7-29cd-4474-8a85-5cf98145f235",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Wash and scrub the potatoes and place them on a rimmed baking sheet pan"
        },
        {
          "ingredient_id": "dc26a170-9087-47be-ae1a-ef3f23c3ca91",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Fill the pan with 3/4 cup water and cover the pan tightly with aluminum foil"
        },
        {
          "ingredient_id": "7af7c6ba-78a4-46ff-83be-993607180344",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place the potatoes on the bottom rack for 25-30 minutes or until they are tender (check by piercing through the foil with a knife)"
        },
        {
          "ingredient_id": "7e6f0d1f-adaf-426d-af0b-26c6dee44d07",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the potatoes from the oven and blot the remaining water with a paper towel"
        },
        {
          "ingredient_id": "03f19667-6190-49b5-9c64-7bf9f488e969",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Allow the potatoes to cool for 10 minutes before coating them with 3 tbsp olive oil"
        },
        {
          "ingredient_id": "4d7817b3-7ee3-431a-a925-202eeb97614a",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Once the potatoes are coated in oil, smash each one with a potato masher (you could also use a fork or even the back of another sheet pan); you want them 1/3\u2033 \u2013 1/2\u2033 thick"
        },
        {
          "ingredient_id": "d3e88c01-0c12-429c-b074-ff33da0b46f6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drizzle the smashed potatoes with the remaining 3 tbsp olive oil"
        },
        {
          "ingredient_id": "e1c174e5-f953-4c45-b56f-bf815274a8be",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Sprinkle your herbs on the potatoes and season generously with salt and pepper"
        },
        {
          "ingredient_id": "52bf69e9-2c72-44ab-a94f-79ef64ea106f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place back in the oven on the top rack for 15 minutes and then lower to the bottom rack for an additional 20-25 minutes or until well browned"
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
}