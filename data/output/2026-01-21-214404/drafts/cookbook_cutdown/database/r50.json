          "ingredient_id": "9772f047-e1cb-4de8-bf43-1cbe9fc70fbb",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "20 g gorgonzola cheese"
        },
        {
          "ingredient_id": "40374250-3648-4c64-9639-562149d095f9",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3 tablespoons cr\u00e8me fra\u00eeche"
        },
        {
          "ingredient_id": "08a632ec-f40f-49fa-8337-269362543824",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/2 teaspoon lemon juice (to taste)"
        },
        {
          "ingredient_id": "1101a318-415d-4620-9da4-adf7edc13281",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "olive oil"
        },
        {
          "ingredient_id": "04841e5d-7d6b-441a-b169-eb77c6e5c6c0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "salt to taste"
        },
        {
          "ingredient_id": "8cfc56a6-6d76-49e4-9560-a8e28f9228b6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Thinly slice the mushrooms and mince the garlic. Add olive oil to a pan and, once heated, add the mushrooms and garlic. Salt, and cook until the mushrooms have let off their liquid and reduced. Add the gorgonzola to the pan, followed by the cr\u00e8me fra\u00eeche. Stir everything together until the cheese has all melted and dissolved into the sauce. Taste your creation and say, \"hmm, this is good, but it's missing something ...\" then add the lemon juice, a little at a time, stirring and tasting after each addition until it's achieved your desired flavour (\"absolutely amazing\")."
        },
        {
          "ingredient_id": "08c00890-82d2-47b4-b076-017a1d9340fc",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "You can serve this with whatever pasta you prefer, but I would recommend making your own pappardelle if you can. (Store bought is obviously fine otherwise.)"
        },
        {
          "ingredient_id": "e48a926d-1e20-4356-ad8d-71cfd73eab96",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "To make your own pasta:"
        },
        {
          "ingredient_id": "e9a3405f-48bb-4e99-9a9b-91b8ab1c91d8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 cups of flour"
        },
        {
          "ingredient_id": "c07d5166-418d-4ccf-a71d-6c3152dacb5f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 large eggs"
        },
        {
          "ingredient_id": "e15450c5-c61d-4a33-a3d3-83d32e0fb2f9",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "A pinch of salt"
        },
        {
          "ingredient_id": "5470391a-11e9-4c0e-9aff-46e92ee7fb93",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Put the flour and salt in a large bowl, make a well in the middle and add the eggs. Whisk them, slowly incorporating the flour. Once the flour has been incorporated fully, turn the dough out onto a floured work surface and knead it until its consistency has become firm and smooth, adding more flour as needed. Roll out the dough either by hand or with a pasta machine to your desired thickness, and cut into ribbons about 2 cm wide."
        }
      ],
