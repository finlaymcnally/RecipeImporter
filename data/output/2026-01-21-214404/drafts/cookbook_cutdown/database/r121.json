    {
      "ingredient_lines": [],
      "instruction": "Label gallon freezer bag with contents, date, and cooking directions."
    },
    {
      "ingredient_lines": [],
      "instruction": "Cut chicken into small bite sized pieces."
    },
    {
      "ingredient_lines": [],
      "instruction": "In freezer bag whisk together brown sugar, ketchup, soy sauce, cornstarch, apple juice, apple cider, bourbon, garlic, ginger, and black pepper."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add chicken, shake bag to coat."
    },
    {
      "ingredient_lines": [],
      "instruction": "Press flat, seal bag securely."
    },
    {
      "ingredient_lines": [],
      "instruction": "Cooking:"
    },
    {
      "ingredient_lines": [],
      "instruction": "Thaw bag contents."
    },
    {
      "ingredient_lines": [],
      "instruction": "Pour chicken and sauce into a slow cooker that has been coated in nonstick cooking spray or lined with a slow cooker bag for easy clean up."
    },
    {
      "ingredient_lines": [],
      "instruction": "Cook on low for 6-7 hours, stirring occasionally."
    },
    {
      "ingredient_lines": [],
      "instruction": "Serve over rice, add fresh steamed broccoli or another favorite veggie for a complete meal."
