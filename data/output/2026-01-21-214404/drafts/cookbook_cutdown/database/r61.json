          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 pound (450g) Gruy\u00e8re cheese, grated"
        },
        {
          "ingredient_id": "f39c66e7-848c-43ec-920d-f017dad78d93",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
