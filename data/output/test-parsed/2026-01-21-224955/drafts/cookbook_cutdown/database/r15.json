    },
    {
      "ingredient_lines": [],
      "instruction": "Remove the bay leaf and thyme branches. If the stew is still"
    },
    {
      "ingredient_lines": [],
      "instruction": "thin, mix a tablespoon of cornstarch with a tablespoon of cold"
    },
    {
      "ingredient_lines": [],
      "instruction": "water to form a slurry. Mix the slurry into the stew and bring the"
    },
    {
      "ingredient_lines": [],
      "instruction": "mixture to a boil. Reduce to a simmer again, stirring occasionally,"
    },
    {
