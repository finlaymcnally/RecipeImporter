    },
    {
      "ingredient_lines": [],
      "instruction": "bacon fat in the pot. Season the beef with salt and pepper and"
    },
    {
      "ingredient_lines": [],
      "instruction": "fry in the bacon fat until browned on all sides. Remove the"
    },
    {
      "ingredient_lines": [],
      "instruction": "beef from the pan and set aside."
    },
    {
      "ingredient_lines": [],
      "instruction": "In the same pot, fry the onion, celery, and carrots until soft"
    },
    {
      "ingredient_lines": [],
      "instruction": "and fragrant, adding a little oil if necessary."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add garlic and fry for another 30 seconds. Stir in the tomato paste."
    },
    {
      "ingredient_lines": [],
      "instruction": "Pour in the Guinness and Worcestershire sauce. Allow to"
    },
    {
      "ingredient_lines": [],
      "instruction": "come to a simmer and stir with a wooden spoon, scraping up"
    },
    {
      "ingredient_lines": [],
      "instruction": "the browned bits from the bottom of the pot."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the beef back to the pot and pour in the chicken broth."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the bay leaf and thyme."
    },
    {
      "ingredient_lines": [],
      "instruction": "Reduce to a simmer and cover. Simmer for 1 1/2 hours."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the potatoes or parsnips and the turnip. Simmer for another"
    },
    {
      "ingredient_lines": [],
      "instruction": "\u00bd hour, or until the vegetables are tender."
    },
    {
      "ingredient_lines": [],
      "instruction": "Remove the bay leaf and thyme branches. If the stew is still"
    },
    {
      "ingredient_lines": [],
      "instruction": "thin, mix a tablespoon of cornstarch with a tablespoon of cold"
    },
    {
      "ingredient_lines": [],
      "instruction": "water to form a slurry. Mix the slurry into the stew and bring the"
    },
    {
      "ingredient_lines": [],
      "instruction": "mixture to a boil. Reduce to a simmer again, stirring occasionally,"
    },
    {
      "ingredient_lines": [],
      "instruction": "and add in the mushrooms if desired. Cook for 10 minutes, uncovered,"
    },
    {
      "ingredient_lines": [],
      "instruction": "until the stew thickens and the mushrooms are cooked through."
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir the bacon back in. Preheat the oven to 350\u00b0F."
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir together the self-rising flour and garlic powder in a medium"
    },
    {
      "ingredient_lines": [],
      "instruction": "bowl. Cut in the shortening until mixture resembles coarse crumbs."
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in the cheddar cheese, then add the milk and stir until the dry"
