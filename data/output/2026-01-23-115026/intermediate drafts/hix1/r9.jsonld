  "identifier": "urn:recipeimport:pdf:020e5142342e0bef5a211cd74199e35cae8dfbb1e66163f7856ffd071629ccb9:c9",
  "name": "TOMATO SALAD WITH LANCASHIRE CHEESE AND PICKLED WALNUTS",
  "recipeIngredient": [
    "400- 450g mixed ripe flavourful tomatoes",
    "2 3 pickled walnuts, plus 1- 2 tbsp of their juice",
    "3- 4 tbsp cold-pressed rapeseed oil",
    "salt and freshly ground black pepper",
    "lOOg aged Lancashire or Cheddar cheese"
  ],
  "recipeInstructions": [
    "Cut the tomatoes into fairly even-sized wedges and chunks, either halving small cherry tomatoes or leaving them whole.",
    "Chop the pickled walnuts into small pieces and mix in a bowl with some of their juice and the rapeseed oil. Season with salt and pepper to taste.",
    "Arrange the tomatoes on individual plates or one large serving platter and spoon over the pickled walnut dressing. Shave the cheese into thin slices with a sharp knife or vegetable peeler and scatter over the tomatoes."
  ],
  "recipeYield": "Serves 4",
