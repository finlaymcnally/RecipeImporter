  "name": "HONEY AND MUSTARD DRESSING",
  "recipeIngredient": [
    "2 tbsp cider vinegar",
    "l tbsp clear honey",
    "l tbsp wholegrain mustard",
    "3 tbsp cold-pressed rapeseed oil",
    "2- 3 tbsp vegetable or corn oil",
    "salt and freshly ground black pepper"
  ],
  "recipeInstructions": [
    "Whisk the cider vinegar, honey, mustard and oils together in a bowl or shake in a screw-topped jar or bottle. Season with salt and pepper to taste."
  ],
  "recipeYield": "Serves 4- 6",
