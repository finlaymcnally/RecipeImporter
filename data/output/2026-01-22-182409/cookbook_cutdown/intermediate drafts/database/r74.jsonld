  "name": "Garlic Baked Grated carrots",
  "recipeIngredient": [
    "4 cups peeled and grated carrots about 5 large carrots",
    "1 tablespoon melted butter plus more for baking pan",
    "1 tablespoon olive oil*",
    "1 tablespoon lemon juice",
    "1/2 teaspoon each salt and pepper",
    "2 cloves garlic minced",
    "1 tablespoon chopped chives optional"
  ],
  "recipeInstructions": [
    "Heat oven to 350 degrees.",
    "Place grated carrots in a buttered 1 \u00bd to 2 quart casserole.",
    "Add remaining ingredients and stir to combine.",
    "Bake for 30 minutes."
  ],
