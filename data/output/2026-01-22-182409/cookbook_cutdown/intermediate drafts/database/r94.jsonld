  "name": "Thai chicken coconut soup",
  "recipeIngredient": [
    "1 lb boneless, skinless chicken breast - sliced",
    "1 medium onion - sliced",
    "12-16oz broccoli",
    "8oz mushrooms - sliced",
    "2-3 carrots - sliced",
    "1-2 tablespoons curry paste",
    "1-2 tablespoons fresh ginger/garlic paste (optional)",
    "1 can coconut milk",
    "2 cups chicken broth"
  ],
  "recipeInstructions": [
    "chicken in a large dutch oven, remove",
    "over medium heat, cook onions until slightly soft, 4-5 minutess",
    "add mushrooms and continue to cook with onions 3-5 minutes",
    "add carrots to onions and cook another 2-3 minutess",
    "remove vetables",
    "scrape fat off top of coconut milk and add to dutch oven",
    "mix curry paste and garlic/ginger into coconut fat, cook for 2-3 minutes",
    "add vegetables back to pot along with coconut milk and broth",
    "cook covered for 10 minutes",
    "add broccoli and cook covered for 5-8 minutes, until broccoli is just tender",
    "add cooked chicken",
    "serve with thai basil (or cilantro), fresh lime and sriracha"
  ],
