  "name": "Chicken & Biscuits Bake",
  "recipeIngredient": [
    "6 tablespoons butter",
    "1 onion, chopped",
    "\u00bd cup flour",
    "3 cups chicken broth",
    "1 teaspoon salt",
    "1 teaspoon pepper",
    "1 cup heavy cream",
    "2\u00bd cups frozen mixed vegetables",
    "1 rotisserie chicken, shredded",
    "2 tubes biscuit dough (8 biscuits each)"
