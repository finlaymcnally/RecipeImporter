  "identifier": "urn:recipeimport:pdf:020e5142342e0bef5a211cd74199e35cae8dfbb1e66163f7856ffd071629ccb9:c19",
  "name": "GREEN SAUCE",
  "recipeIngredient": [
    "30g mint leaves",
    "30g parsley leaves",
    "30g basil leaves",
    "30g capers, rinsed",
    "1 garlic clove, peeled and crushed, or a few wild",
    "garlic leaves",
    "2 tsp Tewkesbury or English mustard",
    "about 1 OOml cold-pressed rapeseed oil"
  ],
  "recipeInstructions": [
    "Put the herb leaves, capers, garlic and mustard into a blender with most of the rapeseed oil and process to a fairly course puree Season with salt and pepper to taste and add a little more oil if the sauce seems a little dry."
  ],
  "recipeYield": "Serves 4",
