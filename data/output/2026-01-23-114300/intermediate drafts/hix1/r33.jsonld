    "For the roasted curry spice mix",
    "1 tbsp fenugreek seeds",
    "1 tbsp fennel seeds",
    "1 tbsp fenugreek leaves",
    "1 tbsp cumin seeds",
    "1- 2 tbsp dried chilli flakes",
    "1;, tbsp caraway seeds",
