    {
      "ingredient_lines": [],
      "instruction": "Rinse off your potatoes and give them a light scrub to remove any excess dirt. Dry with towel then cut into fries."
    },
    {
      "ingredient_lines": [],
      "instruction": "In a large mixing bowl, combine potatoes, olive oil, salt, garlic powder, and paprika until each fry is fully coated in all of the spices."
    },
    {
      "ingredient_lines": [],
      "instruction": "Place fries on a baking sheet lined with parchment paper and bake at 450\u00b0F/230\u00b0C for 30-35 minutes or until the fries are crispy and golden brown."
    },
    {
      "ingredient_lines": [],
      "instruction": "Marinate flank steak with salt, pepper, chili powder, oregano, garlic, cilantro, lime juice, and orange juice for 20 minutes."
    },
    {
      "ingredient_lines": [],
      "instruction": "Heat up a cast-iron skillet with 1 tablespoon of canola oil."
    },
    {
      "ingredient_lines": [],
      "instruction": "Place steak in the hot cast-iron skillet and cook for 3 minutes on both sides for a medium cooked steak. Take steak off the heat and let it rest for 10 minutes before dicing."
    },
    {
      "ingredient_lines": [],
      "instruction": "In an ovenproof skillet, place baked french fries, pepper jack cheese, and diced carne asada, then broil until the cheese is melted."
    },
    {
      "ingredient_lines": [],
      "instruction": "Top with sour cream, guacamole, diced tomatoes, cilantro, and cotija cheese."
