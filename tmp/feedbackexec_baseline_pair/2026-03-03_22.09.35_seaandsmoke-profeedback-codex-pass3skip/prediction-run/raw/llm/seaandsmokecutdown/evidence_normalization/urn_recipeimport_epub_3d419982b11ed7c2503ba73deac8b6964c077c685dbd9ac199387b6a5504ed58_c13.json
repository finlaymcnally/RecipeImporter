      "transform": "normalized"
    },
    {
      "source_block_id": "b486",
      "source_block_index": 486,
      "source_line_index": 0,
      "text": "FOR THE ESCAROLE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b487",
      "source_block_index": 487,
      "source_line_index": 0,
      "text": "Grapeseed oil",
      "transform": "normalized"
    },
    {
      "source_block_id": "b488",
      "source_block_index": 488,
      "source_line_index": 0,
      "text": "2 large heads escarole (about grapefruit size), halved lengthwise",
      "transform": "normalized"
    },
    {
      "source_block_id": "b489",
      "source_block_index": 489,
      "source_line_index": 0,
      "text": "GARNISH",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b490",
      "source_block_index": 490,
      "source_line_index": 0,
      "text": "Pick the thyme tips and wild geranium blossoms into ice water and store them in a damp paper towel-lined container until serving.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b491",
      "source_block_index": 491,
      "source_line_index": 0,
      "text": "ONION SAUCE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b492",
      "source_block_index": 492,
      "source_line_index": 0,
      "text": "Pour half of the onion stock into a very small saucepan. Place an immersion blender in the pan, start blending, and slowly incorporate the xanthan gum, then bring to a simmer and keep warm over low heat. Skim the surface with a strainer and season with a few drops of verjus and cider vinegar.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b493",
      "source_block_index": 493,
      "source_line_index": 0,
      "text": "ESCAROLE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b494",
      "source_block_index": 494,
      "source_line_index": 0,
      "text": "Heat a large skillet over high heat, add a thin layer of grapeseed oil, and when the oil shimmers, add the escarole halves, flat-side down. Cook until nicely charred, about 2 minutes. Reduce the heat to medium, drain any oil from the skillet, and add the remaining half of the onion stock. Allow the escarole to braise for",
      "transform": "normalized"
    },
    {
      "source_block_id": "b494",
      "source_block_index": 494,
      "source_line_index": 0,
      "text": "3 minutes, then flip it and cook for another",
      "transform": "normalized"
    },
    {
      "source_block_id": "b494",
      "source_block_index": 494,
      "source_line_index": 0,
      "text": "3 minutes, constantly basting the escarole as it cooks.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b495",
      "source_block_index": 495,
      "source_line_index": 0,
      "text": "Remove the escarole from the skillet and set it on a paper towel, flat-side up.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b496",
      "source_block_index": 496,
      "source_line_index": 0,
      "text": "TO SERVE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b497",
      "source_block_index": 497,
      "source_line_index": 0,
      "text": "Place a wedge of escarole on each plate and nap it with 2 tablespoons of the onion sauce and",
      "transform": "normalized"
    },
    {
      "source_block_id": "b497",
      "source_block_index": 497,
      "source_line_index": 0,
      "text": "1 teaspoon of thyme oil. Garnish with the thyme tips, geranium flowers, and elderflower and apple capers.",
      "transform": "normalized"
    }
