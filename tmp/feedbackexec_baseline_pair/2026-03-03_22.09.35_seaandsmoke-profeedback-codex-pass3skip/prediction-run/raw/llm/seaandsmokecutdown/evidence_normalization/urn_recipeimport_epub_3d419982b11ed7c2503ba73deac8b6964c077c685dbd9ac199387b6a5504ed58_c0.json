    },
    {
      "source_block_id": "b85",
      "source_block_index": 85,
      "source_line_index": 0,
      "text": "Start your smoker and when it's ready, cold smoke the tuna spine on a half-sheet pan for 1 hour.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b86",
      "source_block_index": 86,
      "source_line_index": 0,
      "text": "Soak the dried smelt in a bowl of cold water for 10 minutes, then drain the water and give the smelt a good rinse under the tap.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b87",
      "source_block_index": 87,
      "source_line_index": 0,
      "text": "Once the tuna spine has finished smoking, heat a large skillet with a film of grapeseed oil over medium-high heat. Add the spine and brown it until golden and cooked through, about 2 minutes per side. Place the bones in a medium saucepan with the smelt and dried shiitakes and cover with the mussel stock and",
      "transform": "normalized"
    },
