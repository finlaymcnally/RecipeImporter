      "text": "25 minutes.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b88",
      "source_block_index": 88,
      "source_line_index": 0,
      "text": "Strain the stock into a 2-quart/",
      "transform": "normalized"
    },
