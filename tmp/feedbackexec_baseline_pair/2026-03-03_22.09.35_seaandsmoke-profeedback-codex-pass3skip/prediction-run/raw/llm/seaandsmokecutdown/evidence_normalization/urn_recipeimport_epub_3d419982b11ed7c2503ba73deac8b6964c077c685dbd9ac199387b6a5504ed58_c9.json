    {
      "source_block_id": "b376",
      "source_block_index": 376,
      "source_line_index": 0,
      "text": "FOR THE GRILLED ROMANO BEANS",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b377",
      "source_block_index": 377,
      "source_line_index": 0,
      "text": "11/2 ounces/",
      "transform": "normalized"
    },
    {
      "source_block_id": "b377",
      "source_block_index": 377,
      "source_line_index": 0,
      "text": "40 g frozen Mangalitsa lardo",
      "transform": "normalized"
    },
    {
      "source_block_id": "b378",
      "source_block_index": 378,
      "source_line_index": 0,
      "text": "8 ounces/",
      "transform": "normalized"
    },
    {
      "source_block_id": "b378",
      "source_block_index": 378,
      "source_line_index": 0,
      "text": "240 g Romano beans",
      "transform": "normalized"
    },
    {
      "source_block_id": "b379",
      "source_block_index": 379,
      "source_line_index": 0,
      "text": "8 sprigs oregano",
      "transform": "normalized"
    },
    {
      "source_block_id": "b380",
      "source_block_index": 380,
      "source_line_index": 0,
      "text": "Grapeseed oil",
      "transform": "normalized"
    },
    {
      "source_block_id": "b381",
      "source_block_index": 381,
      "source_line_index": 0,
      "text": "HERB SAUCE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b382",
      "source_block_index": 382,
      "source_line_index": 0,
      "text": "Crush the marjoram, oregano, parsley, oil, and anchovy with a mortar and pestle to form a thick paste. Season the sauce with salt, verjus, and fermented green garlic brine and immediately transfer it to the refrigerator, with a piece of parchment cut to fit directly on the surface of the sauce to prevent any discoloration.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b383",
      "source_block_index": 383,
      "source_line_index": 0,
      "text": "GRILLED ROMANO BEANS",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b384",
      "source_block_index": 384,
      "source_line_index": 0,
      "text": "Grate the frozen lardo into a medium mixing bowl. Wearing plastic gloves, work it into a smooth paste with your hands. Transfer the lardo into a small piping bag and allow it to warm to room temperature.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b385",
      "source_block_index": 385,
      "source_line_index": 0,
      "text": "Trim the stem ends from the Romano beans and tie them with the oregano sprigs into 4 tight bundles with kitchen twine.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b386",
      "source_block_index": 386,
      "source_line_index": 0,
      "text": "Prepare a grill for direct grilling, brush the bundled beans with grapeseed oil, and grill them, rotating occasionally. When the beans are just cooked through, remove them from the heat, untie, and discard the oregano.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b387",
      "source_block_index": 387,
      "source_line_index": 0,
      "text": "TO SERVE",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b388",
      "source_block_index": 388,
      "source_line_index": 0,
      "text": "Pipe a quarter of the lardo into the center of each bundle of beans, turning each bundle to dress it with the lardo. Plate the bundles and nap each plate with a full tablespoon of the herb sauce.",
      "transform": "normalized"
    }
  ],
