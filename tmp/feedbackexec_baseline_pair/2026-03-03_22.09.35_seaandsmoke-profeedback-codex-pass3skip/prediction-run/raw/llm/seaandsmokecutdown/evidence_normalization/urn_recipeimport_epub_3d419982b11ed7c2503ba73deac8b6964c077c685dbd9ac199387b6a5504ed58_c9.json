  "line_rows": [
    {
      "source_block_id": "b364",
      "source_block_index": 364,
      "source_line_index": 0,
      "text": "BUNDLES OF ROMANO BEANS ROASTED OVER OREGANO SPRIGS",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b365",
      "source_block_index": 365,
      "source_line_index": 0,
      "text": "Romano beans are at their best before they are fully grown and getting a bit stringy. The beans must be amazing raw in order to be amazing cooked, and we simply bundle them around sprigs of oregano and grill them over hot coals. When the outside has a good char, we pull them from the grill and baste them with a flavorful herb sauce and lardo.",
      "transform": "normalized"
    },
    {
      "source_block_id": "b366",
      "source_block_index": 366,
      "source_line_index": 0,
      "text": "SERVES 4",
      "transform": "heading_preserved"
    },
    {
      "source_block_id": "b367",
      "source_block_index": 367,
      "source_line_index": 0,
      "text": "FOR THE HERB SAUCE",
      "transform": "heading_preserved"
    },
