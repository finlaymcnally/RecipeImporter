{
  "recipe": {
    "description": null,
    "notes": "Tags: Side, Normal, potatoes",
    "title": "Roasted Smashed potatoes",
    "yield_detail": null,
    "yield_phrase": null,
    "yield_unit_name": null,
    "yield_units": 1
  },
  "schema_v": 1,
  "steps": [
    {
      "ingredient_lines": [
        {
          "ingredient_id": "4283b02c-d628-458e-899c-5ac678f0fb20",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "INGREDIENTS"
        },
        {
          "ingredient_id": "e05d5c71-ddf3-46b5-b77f-9214f3cbd984",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 lb. baby red bliss or yukon gold potatoes (you want them to be small \u2013 like, golfball size \u2013 about 18 potatoes)"
        },
        {
          "ingredient_id": "b8538f15-bbcd-40e8-952f-43f8c69772db",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6 tbsp olive oil, divided"
        },
        {
          "ingredient_id": "cac910b0-abae-423e-a039-fdc8704db600",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 tsp fresh thyme, chopped (feel free to substitute with rosemary, basil, garlic, parmesan)"
        },
        {
          "ingredient_id": "961fdbf0-9a47-431d-ab01-5cf02ef7b32f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Salt and pepper, to taste"
        },
        {
          "ingredient_id": "9f4e1125-26fc-404e-a30a-2cec96a46e04",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "HOW TO MAKE IT"
        },
        {
          "ingredient_id": "c5891e12-a698-41ae-a014-01a168f4bd66",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Preheat the oven to 500\u00b0F"
        },
        {
          "ingredient_id": "2d1fa6b9-ce42-4d77-abf2-763ea0898620",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Wash and scrub the potatoes and place them on a rimmed baking sheet pan"
        },
        {
          "ingredient_id": "64d5e6b9-494b-49a7-89fb-5acf471e781d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Fill the pan with 3/4 cup water and cover the pan tightly with aluminum foil"
        },
        {
          "ingredient_id": "448422db-e52c-43fe-b009-a824cc49e397",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place the potatoes on the bottom rack for 25-30 minutes or until they are tender (check by piercing through the foil with a knife)"
        },
        {
          "ingredient_id": "271db84d-e894-40f9-8825-2f517e418577",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Remove the potatoes from the oven and blot the remaining water with a paper towel"
        },
        {
          "ingredient_id": "454c26cb-5dfe-4c47-a992-3ebbeffb47a2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Allow the potatoes to cool for 10 minutes before coating them with 3 tbsp olive oil"
        },
        {
          "ingredient_id": "7bd294f9-ff15-4b28-b6b6-4c3b84258ec2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Once the potatoes are coated in oil, smash each one with a potato masher (you could also use a fork or even the back of another sheet pan); you want them 1/3\u2033 \u2013 1/2\u2033 thick"
        },
        {
          "ingredient_id": "fb718a52-3451-4b60-b4a1-176c4593a0cf",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drizzle the smashed potatoes with the remaining 3 tbsp olive oil"
        },
        {
          "ingredient_id": "3615a072-bcad-485b-889d-01c3d46d5027",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Sprinkle your herbs on the potatoes and season generously with salt and pepper"
        },
        {
          "ingredient_id": "a82fad36-088d-431d-8545-2c9eb3e35833",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Place back in the oven on the top rack for 15 minutes and then lower to the bottom rack for an additional 20-25 minutes or until well browned"
        }
      ],
      "instruction": "See original recipe for details."
    }
  ]
}