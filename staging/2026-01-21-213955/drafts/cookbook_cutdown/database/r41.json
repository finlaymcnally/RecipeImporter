      "instruction": "Step 1"
    },
    {
      "ingredient_lines": [],
      "instruction": "Bring a large pot of lightly salted water to a boil. Add linguine pasta, and cook for 8 to 10 minutes, or until al dente; drain."
    },
    {
      "ingredient_lines": [],
      "instruction": "Step 2"
    },
    {
      "ingredient_lines": [],
      "instruction": "In a large skillet, melt the butter over medium heat. Stir in cream, and season with pepper. Cook 6 to 8 minutes, stirring constantly."
    },
    {
      "ingredient_lines": [],
      "instruction": "Step 3"
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir Parmesan cheese into cream sauce, stirring until thoroughly mixed. Blend in the pesto, and cook for 3 to 5 minutes, until thickened."
    },
    {
      "ingredient_lines": [],
      "instruction": "Step 4"
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in the shrimp, and cook until they turn pink, about 5 minutes. Serve over the hot linguine."
    }
