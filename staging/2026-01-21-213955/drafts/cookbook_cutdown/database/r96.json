        },
        {
          "ingredient_id": "c43007d9-13a8-468d-9554-cbd0ffe87a39",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 eggs"
        },
        {
          "ingredient_id": "2cd4f8b6-9567-46aa-87c4-0ba96ebfc4e5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 t salt"
        },
        {
          "ingredient_id": "11851e14-e967-423c-8a0b-4089b52bdcee",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1/4 t black pepper"
        },
        {
          "ingredient_id": "63fe13e4-454c-4bc2-9f8c-b647c43411d5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Canola oil"
        },
        {
          "ingredient_id": "5fd2bb86-4a9a-446c-bb90-c26977d509f2",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Using the steel blade of your food processor put in the potatoes and grind them to mush. Or you can shred some and mush some which is what I do so they have a bit of texture. Put in a colander and push out as much liquid as you can. At this point I also squeeze my mixture in a big piece of cheese cloth to extract as much moisture as possible."
        },
        {
          "ingredient_id": "66dad463-7b76-40b0-9d69-1dcd99f96af5",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Transfer to a bowl and add the shredded or chopped onion, matzoh meal, baking powder, eggs, salt and pepper and mix with hands until well combined. Heat oil at a medium temperature in a large skillet to the depth of about a \u00bd inch. (Mine is"
        },
        {
          "ingredient_id": "6e0e68ae-773a-46a5-9c0c-6a7e400904c7",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "nonstick, but a cast iron works really well, too.)"
        },
        {
          "ingredient_id": "d31b13d2-90ae-4db7-a3c6-a35270d03871",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drop spoonfuls of the batter into the pan. Fry over medium heat for 3-4 minutes on each side until both sides are brown and crisp."
        },
        {
          "ingredient_id": "f70538e4-1d17-4c9b-86ff-5b629ebfe738",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Drain on paper towels or a paper grocery bag. Keep warm while frying the rest of the mixture. You may have to add more oil as necessary."
        },
        {
          "ingredient_id": "149a4063-876a-42d4-938c-8f504dc1ad1f",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "If you want to make these ahead-I put them in a very cold refrigerator or freezer. Then when you are ready to serve place them on a baking sheet into a preheated 450 oven for about 5 minutes. It works!"
        }
      ],
