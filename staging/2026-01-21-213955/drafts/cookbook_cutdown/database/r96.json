          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "4 egg whites"
        },
        {
          "ingredient_id": "a0ed5699-de14-4a79-b9f1-4a784afb22f0",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 T cornstarch"
        },
        {
          "ingredient_id": "cfe687b1-065c-4297-8b03-67b7af8f0093",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "5 T unsalted butter"
        },
        {
          "ingredient_id": "00bcac31-9a65-403f-8d4d-f9d205596193",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "6 1/2 T sunflower oil (I used canola)"
        },
        {
          "ingredient_id": "30dfe099-1ef9-4c21-97e9-893bb53426a8",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "1 t salt"
        },
        {
          "ingredient_id": "5857662b-d4fb-43ca-a75f-5c70bfb6d1dc",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Pepper"
        },
        {
          "ingredient_id": "ddbf1337-bcbf-46b0-8616-e882a20bc33d",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Rinse the grated potatoes in cold water. (I used the shredding disc on my food processor.) Drain in a colander and squeeze out any excess water. Then spread the potatoes on a dry kitchen towel to dry completely."
        },
        {
          "ingredient_id": "b5ed138c-f300-464e-9104-852f8fbb56ad",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "In a large bowl mix the potato, parsnips, chives or onion, egg whites, cornstarch, salt and plenty of black pepper."
        },
        {
          "ingredient_id": "65456f4c-ab12-4b91-9396-e7a07daa1e4b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Heat \u00bd the butter and \u00bd the oil in a large frying pan over medium high heat. Use your hands to pick up portions of about 2 T of the latke mix. Squeeze firmly to remove some of the liquid and shape into patties about 3/8\u201d thick."
        },
        {
          "ingredient_id": "21e0838c-32a1-4374-b6e0-5aebea926c22",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Carefully place as many patties as can fit in the pan. Push them down gently and level them with the back of a spoon. Fry for 3 minutes on each side until they are completely brown on each side. Drain on paper towels and keep warm while you fry the rest using the reserved butter and oil."
        },
        {
          "ingredient_id": "d058d732-b032-428d-9e0d-06e6eda58423",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Serve with sour cream, jam, sugar and apple sauce. And remember these do not need to be made just once a year."
        },
        {
          "ingredient_id": "f2d07db1-f9c3-48c4-8c21-74474b076ab6",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "Traditional Latkes"
        },
        {
          "ingredient_id": "e26af970-eb17-4457-83d1-c555f9ac3e58",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "3 large peeled potatoes About 1 \u00bd pounds (I used a combo of russets and yukons.)"
        },
        {
          "ingredient_id": "c76751d2-eab9-4b68-98ba-ed681b468e3b",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "2 grated onions"
        },
        {
          "ingredient_id": "7b6a9831-974c-46d7-b294-39d48f59dacd",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
