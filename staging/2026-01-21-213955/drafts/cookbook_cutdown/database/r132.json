          "ingredient_id": "fae5d09b-52c0-42a8-8d24-ce6ca3967088",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u2022 1 gallon-sized plastic freezer bag"
        },
        {
          "ingredient_id": "cee22f93-471e-4f58-a7b5-7cf5ed0f7322",
          "input_qty": null,
          "input_unit_id": null,
          "is_optional": false,
          "note": null,
          "quantity_kind": "unquantified",
          "raw_text": "\u2022 1 quart-sized plastic freezer bag (or two if you buy a 12oz can of milk)"
