    {
      "ingredient_lines": [],
      "instruction": "Press the saut\u00e9 button on the Instant Pot, add the oil and allow it to heat up for a minute. Add the cumin seeds and once they start to brown, add the onion and bay leaf. Stir-fry for 6-7 minutes or until the onion begins to brown."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the garlic, ginger, spices and stir, then add the tomatoes. Cook for 5 minutes, or until the tomatoes break down."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the lentils to the pot along with the 3 cups of water and mix well."
    },
    {
      "ingredient_lines": [],
      "instruction": "Secure the lid, close the pressure valve and cook for 30 minutes at high pressure."
    },
    {
      "ingredient_lines": [],
      "instruction": "Allow the pressure to release naturally."
    },
    {
      "ingredient_lines": [],
      "instruction": "Stir in the ghee and garnish with cilantro if desired."
