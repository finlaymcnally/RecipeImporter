        }
      ],
      "instruction": "Preheat oven to 350\u02daF/180\u02daC."
    },
    {
      "ingredient_lines": [],
      "instruction": "In a large pot over medium-high heat, melt the butter."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the onion, stir until softened. About 1 minute."
    },
    {
      "ingredient_lines": [],
      "instruction": "Whisk in the flour, stirring constantly to prevent the flour from browning. About 1 minute."
    },
    {
      "ingredient_lines": [],
      "instruction": "Whisk in the chicken broth, salt, and pepper. Continue to whisk until no lumps remain."
    },
    {
      "ingredient_lines": [],
      "instruction": "Whisk in the heavy cream. Bring to a light simmer until the sauce has thickened slightly. Test for additional salt/pepper."
    },
    {
      "ingredient_lines": [],
      "instruction": "Add the mixed vegetables and shredded chicken, stir until fully incorporated."
    },
    {
      "ingredient_lines": [],
      "instruction": "Transfer to a 9x13-inch baking dish."
    },
    {
      "ingredient_lines": [],
      "instruction": "Evenly top with 12 pieces of biscuit dough (you will have extra biscuits, which can be baked off separately)."
    },
    {
      "ingredient_lines": [],
      "instruction": "Bake in a preheated oven for 20 minutes, until the biscuits are golden and the gravy mixture is bubbling."
    },
    {
      "ingredient_lines": [],
      "instruction": "Cool slightly before serving."
    }
  ]
