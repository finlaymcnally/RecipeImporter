{
  "pipeline_id": "recipe.knowledge.compact.v1",
  "description": "Extract reusable cooking knowledge snippets from non-recipe cookbook text using compact pass4 input bundles.",
  "prompt_template_path": "prompts/recipe.knowledge.compact.v1.prompt.md",
  "output_schema_path": "schemas/recipe.knowledge.v1.output.schema.json",
  "input_glob_default": "**/*.json",
  "output_ext": ".json",
  "prompt_input_mode": "inline",
  "codex_model": "gpt-5.3-codex-spark",
  "codex_sandbox": "read-only",
  "codex_ask_for_approval": "never",
  "codex_web_search": "disabled",
  "codex_timeout_seconds": 600,
  "codex_cd_mode": "asset_root"
}
