{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recipe.schemaorg.v1 output",
  "description": "Output contract for pass2 schema extraction. Input may include normalized evidence helper fields, but output remains grounded in canonical evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "recipe_id",
    "schemaorg_recipe",
    "extracted_ingredients",
    "extracted_instructions",
    "field_evidence",
    "warnings"
  ],
  "properties": {
    "bundle_version": {
      "type": "string",
      "const": "1"
    },
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "schemaorg_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@context",
        "@type",
        "name",
        "description",
        "recipeYield",
        "recipeIngredient",
        "recipeInstructions",
        "comment"
      ],
      "properties": {
        "@context": {
          "type": [
            "string",
            "null"
          ]
        },
        "@type": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipeYield": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipeIngredient": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recipeInstructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "extracted_ingredients": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extracted_instructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "field_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "recipeYield",
        "recipeIngredient",
        "recipeInstructions",
        "comment"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipeYield": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipeIngredient": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recipeInstructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
