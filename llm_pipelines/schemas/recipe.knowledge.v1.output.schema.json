{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recipe.knowledge.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "bid", "r"],
  "properties": {
    "v": {
      "type": "string",
      "const": "2"
    },
    "bid": {
      "type": "string",
      "minLength": 1
    },
    "r": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cid", "u", "d", "s"],
        "properties": {
          "cid": {
            "type": "string",
            "minLength": 1
          },
          "u": {
            "type": "boolean"
          },
          "d": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["i", "c", "gr"],
              "properties": {
                "i": {
                  "type": "integer",
                  "minimum": 0
                },
                "c": {
                  "type": "string",
                  "enum": ["knowledge", "other"]
                },
                "gr": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tk", "ck", "pt"],
                  "properties": {
                    "tk": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "ck": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "pt": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["k", "d", "ck"],
                        "properties": {
                          "k": {
                            "type": "string",
                            "minLength": 1
                          },
                          "d": {
                            "type": "string",
                            "minLength": 1
                          },
                          "ck": {
                            "type": "string",
                            "minLength": 1
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "s": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["b", "e"],
              "properties": {
                "b": {
                  "type": "string",
                  "minLength": 1
                },
                "e": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["i", "q"],
                    "properties": {
                      "i": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "q": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
