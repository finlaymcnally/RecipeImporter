{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "prelabel.freeform.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selections"
  ],
  "properties": {
    "selections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "block_index",
          "quote",
          "occurrence",
          "start",
          "end"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "block_index": {
            "type": [
              "integer",
              "null"
            ]
          },
          "quote": {
            "type": [
              "string",
              "null"
            ]
          },
          "occurrence": {
            "type": [
              "integer",
              "null"
            ]
          },
          "start": {
            "type": [
              "integer",
              "null"
            ]
          },
          "end": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      }
    }
  }
}
