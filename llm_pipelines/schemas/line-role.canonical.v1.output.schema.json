{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "line-role.canonical.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "labels"
  ],
  "properties": {
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "RECIPE_TITLE",
          "INGREDIENT_LINE",
          "INSTRUCTION_LINE",
          "HOWTO_SECTION",
          "YIELD_LINE",
          "TIME_LINE",
          "RECIPE_NOTES",
          "RECIPE_VARIANT",
          "NONRECIPE_CANDIDATE",
          "NONRECIPE_EXCLUDE"
        ]
      }
    }
  }
}
