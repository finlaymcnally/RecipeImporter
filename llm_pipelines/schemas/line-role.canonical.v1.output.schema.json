{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "line-role.canonical.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rows"
  ],
  "properties": {
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "row_id",
          "label"
        ],
        "properties": {
          "row_id": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "enum": [
              "RECIPE_TITLE",
              "INGREDIENT_LINE",
              "INSTRUCTION_LINE",
              "HOWTO_SECTION",
              "YIELD_LINE",
              "TIME_LINE",
              "RECIPE_NOTES",
              "RECIPE_VARIANT",
              "NONRECIPE_CANDIDATE",
              "NONRECIPE_EXCLUDE"
            ]
          }
        }
      }
    }
  }
}
