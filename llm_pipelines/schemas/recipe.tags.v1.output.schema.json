{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recipe.tags.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "recipe_id",
    "selected_tags",
    "new_tag_proposals"
  ],
  "properties": {
    "bundle_version": {
      "type": "string",
      "const": "1"
    },
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_tags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tag_key_norm",
          "category_key_norm",
          "confidence",
          "evidence"
        ],
        "properties": {
          "tag_key_norm": {
            "type": "string",
            "minLength": 1
          },
          "category_key_norm": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "new_tag_proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposed_category",
          "display_name",
          "rationale"
        ],
        "properties": {
          "proposed_category": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
