{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recipe.final.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "recipe_id",
    "draft_v1",
    "ingredient_step_mapping",
    "ingredient_step_mapping_reason",
    "warnings"
  ],
  "properties": {
    "bundle_version": {
      "type": "string",
      "const": "1"
    },
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "draft_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_v",
        "source",
        "recipe",
        "steps"
      ],
      "properties": {
        "schema_v": {
          "type": "integer",
          "const": 1
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipe": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "instruction",
              "ingredient_lines"
            ],
            "properties": {
              "instruction": {
                "type": "string",
                "minLength": 1
              },
              "ingredient_lines": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "ingredient_step_mapping": {
      "type": "array",
      "description": "Ordered mapping entries from ingredient line indexes to step indexes.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ingredient_index",
          "step_indexes"
        ],
        "properties": {
          "ingredient_index": {
            "type": "integer",
            "minimum": 0
          },
          "step_indexes": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "ingredient_step_mapping_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Short machine-readable reason when ingredient_step_mapping is intentionally empty."
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
