{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recipe.merged-repair.v1 output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "recipe_id",
    "canonical_recipe",
    "ingredient_step_mapping",
    "warnings"
  ],
  "properties": {
    "bundle_version": {
      "type": "string",
      "const": "1"
    },
    "recipe_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_recipe": {
      "type": "string",
      "description": "JSON-stringified canonical recipe object with title, ingredients, and steps.",
      "minLength": 2
    },
    "ingredient_step_mapping": {
      "type": "string",
      "description": "JSON-stringified mapping from ingredient lines to step ids.",
      "minLength": 2
    },
    "ingredient_step_mapping_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Short machine-readable reason when ingredient_step_mapping is intentionally empty."
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
