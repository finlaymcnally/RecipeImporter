                "items": {
                  "type": "string"
                }
              },
              "s": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "d": {
                "type": ["string", "null"]
              },
              "y": {
                "type": ["string", "null"]
              }
            }
          },
